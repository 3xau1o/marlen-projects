{
  "m": {
    "l": "ts",
    "e": {
      "k": "p5js",
      "p": {
        "v": "1",
        "ml5": false,
        "sound": false
      }
    }
  },
  "o": {
    "c": {}
  },
  "fs": {
    "k": "tree",
    "v": 1,
    "r": {
      "k": 0,
      "c": {
        "index.ts": {
          "k": 1,
          "c": "// ── Constantes ────────────────────────────────────────────────────────────\nconst RADIO        = 25;\nconst GRAVEDAD     = 0.5;\nconst FUERZA_SALTO = -16;\nconst PLAT_H       = 14;\nconst SEPARACION   = 65;\nconst VELOCIDAD    = 5.5;\n\n// ── Estado global ─────────────────────────────────────────────────────────\nlet jugX, jugY, jugZ, velX, velY, velZ;\nlet plataformas = [];\nlet siguientePlataY, alturaMax, lineaMuerteY;\nlet puntos, record = 0, estado = 'inicio';\n\nlet anguloCam = 0, clickIzquierdo = false, ultimoMouseX = 0;\nlet estela = [], particulas = [], estrellas = [];\n\n// ── Setup ─────────────────────────────────────────────────────────────────\nfunction setup() {\n  setAttributes('antialias', true);\n  // Hacemos el canvas de pantalla completa\n  createCanvas(windowWidth, windowHeight, WEBGL);\n  frameRate(60);\n\n  // Inyectamos la UI de texto nativa (HTML/CSS)\n  configurarUIHTML();\n\n  for (let i = 0; i < 80; i++) {\n    estrellas.push({\n      x: random(-1500, 1500), y: random(-3500, 500), z: random(-1000, 1000),\n      brillo: random(100, 255), velocidad: random(0.02, 0.08), tam: random() < 0.1 ? 3 : 1.5\n    });\n  }\n}\n\nfunction windowResized() {\n  resizeCanvas(windowWidth, windowHeight);\n}\n\n// ── Interfaz HTML / CSS (Glow Realista) ───────────────────────────────────\nfunction configurarUIHTML() {\n  const estilo = document.createElement('style');\n  estilo.innerHTML = `\n    body { margin: 0; padding: 0; background: #050510; color: #00ffe7; font-family: 'Courier New', monospace; overflow: hidden; user-select: none; }\n    canvas { display: block; position: absolute; top: 0; left: 0; z-index: 1; }\n    #ui-capa { position: absolute; inset: 0; z-index: 10; pointer-events: none; display: flex; flex-direction: column; justify-content: center; align-items: center; }\n    \n    .pantalla { text-align: center; background: rgba(5,5,15,0.7); padding: 40px 60px; border: 1px solid rgba(0,255,231,0.3); border-radius: 12px; backdrop-filter: blur(8px); }\n    .oculto { display: none !important; }\n    \n    h1 { font-size: 64px; margin: 0 0 10px 0; letter-spacing: 4px; text-shadow: 0 0 20px currentColor, 0 0 40px currentColor; }\n    p { font-size: 18px; color: #fff; opacity: 0.8; line-height: 1.6; text-shadow: 0 0 8px rgba(255,255,255,0.5); }\n    .parpadeo { animation: blink 1s infinite alternate; margin-top: 30px; font-weight: bold; }\n    @keyframes blink { from { opacity: 1; text-shadow: 0 0 15px currentColor; } to { opacity: 0.3; text-shadow: none; } }\n    \n    /* Colores Neón */\n    .cyan { color: #00ffe7; }\n    .oro  { color: #ffcc00; text-shadow: 0 0 15px #ffcc00 !important; font-weight: bold; }\n    .rojo { color: #ff3366; }\n    \n    /* HUD del juego (Puntos) */\n    #hud { position: absolute; top: 30px; left: 30px; text-align: left; font-size: 32px; font-weight: bold; text-shadow: 0 0 15px #00ffe7; }\n    #hud-record { font-size: 16px; opacity: 0.8; margin-top: 5px; }\n    \n    /* Popups de puntos (Toasts) */\n    #toast-container { position: absolute; top: 50%; left: 65%; transform: translateY(-50%); text-align: left; }\n    .toast { color: #ffcc00; font-size: 24px; font-weight: bold; text-shadow: 0 0 15px #ffcc00; margin-bottom: 8px; animation: flotar 0.8s ease-out forwards; }\n    @keyframes flotar { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-40px) scale(1.2); } }\n  `;\n  document.head.appendChild(estilo);\n\n  const ui = document.createElement('div');\n  ui.id = 'ui-capa';\n  ui.innerHTML = `\n    <div id=\"hud\" class=\"oculto\">\n      PUNTOS: <span id=\"val-puntos\">0</span>\n      <div id=\"hud-record\" class=\"oro\">RÉCORD: <span id=\"val-record\">0</span></div>\n    </div>\n    \n    <div id=\"toast-container\"></div>\n\n    <div id=\"pantalla-inicio\" class=\"pantalla\">\n      <h1 class=\"cyan\">BOUNCE UP 3D</h1>\n      <p>Mueve con <b>WASD</b> o <b>Flechas</b><br>Click Izq + Arrastrar = Girar Cámara</p>\n      <p class=\"oro oculto\" id=\"inicio-record-txt\">RÉCORD ACTUAL: <span id=\"inicio-record\">0</span></p>\n      <div class=\"cyan parpadeo\">[ PRESIONA UNA TECLA PARA EMPEZAR ]</div>\n    </div>\n\n    <div id=\"pantalla-muerte\" class=\"pantalla oculto\">\n      <h1 class=\"rojo\">ELIMINADO</h1>\n      <p style=\"font-size: 28px;\">PUNTUACIÓN FINAL: <strong id=\"final-puntos\" class=\"cyan\">0</strong></p>\n      <p class=\"oro\">MEJOR RÉCORD: <span id=\"final-record\">0</span></p>\n      <div class=\"rojo parpadeo\">[ PRESIONA UNA TECLA PARA REINTENTAR ]</div>\n    </div>\n  `;\n  document.body.appendChild(ui);\n}\n\n// ── Control de UI ─────────────────────────────────────────────────────────\nfunction actualizarHUD() {\n  document.getElementById('val-puntos').innerText = puntos;\n  document.getElementById('val-record').innerText = record;\n}\n\nfunction mostrarPopupTexto(cantidad, esMovil) {\n  const toast = document.createElement('div');\n  toast.className = 'toast';\n  toast.innerText = '+' + cantidad;\n  if (!esMovil) toast.style.color = '#00ffe7'; \n  document.getElementById('toast-container').appendChild(toast);\n  setTimeout(() => toast.remove(), 800);\n}\n\nfunction cambiarPantalla(nueva) {\n  document.getElementById('pantalla-inicio').classList.add('oculto');\n  document.getElementById('pantalla-muerte').classList.add('oculto');\n  document.getElementById('hud').classList.add('oculto');\n\n  if (nueva === 'inicio') {\n    document.getElementById('pantalla-inicio').classList.remove('oculto');\n    if (record > 0) {\n      document.getElementById('inicio-record-txt').classList.remove('oculto');\n      document.getElementById('inicio-record').innerText = record;\n    }\n  } \n  else if (nueva === 'jugando') {\n    document.getElementById('hud').classList.remove('oculto');\n    actualizarHUD();\n  } \n  else if (nueva === 'gameover') {\n    document.getElementById('pantalla-muerte').classList.remove('oculto');\n    document.getElementById('final-puntos').innerText = puntos;\n    document.getElementById('final-record').innerText = record;\n  }\n}\n\n// ── Loop principal ────────────────────────────────────────────────────────\nfunction draw() {\n  background(5, 5, 12); \n\n  if (estado === 'inicio' || estado === 'gameover') return;\n\n  perspective(PI / 3, width / height, 0.1, 5000);\n  if (clickIzquierdo) { anguloCam += (mouseX - ultimoMouseX) * 0.006; ultimoMouseX = mouseX; }\n  \n  camera(jugX + sin(anguloCam) * 520, jugY - 280, jugZ + cos(anguloCam) * 520,\n         jugX, jugY - 60, jugZ, 0, 1, 0);\n\n  // Iluminación ajustada para resaltar el efecto Glass\n  ambientLight(40, 40, 60);\n  directionalLight(255, 255, 255, -0.5, -1, -0.3);\n  \n  // Luz puntual atada al jugador (hace que las plataformas brillen al acercarse)\n  pointLight(0, 255, 231, jugX, jugY - 50, jugZ);\n\n  actualizarFisica();\n\n  while (siguientePlataY > jugY - 1400) generarPlataforma();\n  plataformas = plataformas.filter(p => p.y < jugY + 500);\n\n  dibujarEstrellas();\n  dibujarSuelo();\n  dibujarBordes();\n  \n  // Para la transparencia (glass), p5 necesita que los elementos se dibujen ordenados de atrás hacia adelante\n  // o simplemente activamos un buen modo de mezcla, pero por defecto el depth testing hace su trabajo si lo dibujamos así:\n  for (let p of plataformas) { moverPlataforma(p); dibujarPlataforma(p); }\n  \n  dibujarParticulas();\n  dibujarEstela();\n  dibujarJugador();\n\n  if (jugY < alturaMax) alturaMax = jugY;\n  lineaMuerteY = alturaMax + 480;\n  \n  if (jugY > lineaMuerteY) { \n    estado = 'gameover'; \n    cambiarPantalla('gameover');\n  }\n}\n\n// ── Física ────────────────────────────────────────────────────────────────\nfunction actualizarFisica() {\n  let adelX =  sin(anguloCam), adelZ =  cos(anguloCam); \n  let derX  =  cos(anguloCam), derZ  = -sin(anguloCam); \n\n  velX = 0; velZ = 0;\n  if (keyIsDown(UP_ARROW)    || keyIsDown(87)) { velX -= adelX * VELOCIDAD; velZ -= adelZ * VELOCIDAD; }\n  if (keyIsDown(DOWN_ARROW)  || keyIsDown(83)) { velX += adelX * VELOCIDAD; velZ += adelZ * VELOCIDAD; }\n  if (keyIsDown(RIGHT_ARROW) || keyIsDown(68)) { velX += derX  * VELOCIDAD; velZ += derZ  * VELOCIDAD; }\n  if (keyIsDown(LEFT_ARROW)  || keyIsDown(65)) { velX -= derX  * VELOCIDAD; velZ -= derZ  * VELOCIDAD; }\n\n  velY += GRAVEDAD;\n  jugX += velX; jugY += velY; jugZ += velZ;\n\n  if (jugX >  420) jugX -= 840;\n  if (jugX < -420) jugX += 840;\n  if (jugZ >  320) jugZ -= 640;\n  if (jugZ < -320) jugZ += 640;\n\n  for (let p of plataformas) {\n    let tope     = p.y - p.h / 2;\n    let curBase  = jugY + RADIO;\n    let prevBase = curBase - velY;\n    if (abs(jugX - p.x) < p.ancho / 2 &&\n        abs(jugZ - p.z) < p.prof  / 2 &&\n        velY > 0 && prevBase <= tope && curBase >= tope) {\n      jugY = tope - RADIO;\n      velY = FUERZA_SALTO;\n      \n      spawnParticulas(jugX, jugY + RADIO, jugZ, p.movil ? [255, 204, 0] : [0, 255, 231]);\n      \n      if (!p.visitada) {\n        let pts = p.movil ? 15 : 5;\n        puntos += pts;\n        if (puntos > record) record = puntos;\n        p.visitada = true;\n        actualizarHUD();\n        mostrarPopupTexto(pts, p.movil); \n      }\n    }\n  }\n}\n\n// ── Dibujo 3D ───────────────────────────────────────────────\nfunction dibujarJugador() {\n  push();\n    translate(jugX, jugY, jugZ);\n    if (abs(velX) > 0.5 || abs(velZ) > 0.5) {\n      rotateY(atan2(velX, velZ));\n      rotateX(frameCount * 0.09);\n    }\n    noStroke();\n    emissiveMaterial(0, 255, 231);\n    sphere(RADIO, 16, 16);\n    \n    noFill();\n    strokeWeight(1);\n    stroke(255);\n    sphere(RADIO * 1.15, 8, 8);\n  pop();\n}\n\nfunction dibujarEstela() {\n  estela.push({ x: jugX, y: jugY, z: jugZ });\n  if (estela.length > 8) estela.shift();\n  \n  for (let i = 0; i < estela.length - 1; i++) {\n    let s = RADIO * (i / estela.length) * 0.55;\n    push();\n      translate(estela[i].x, estela[i].y, estela[i].z);\n      noStroke();\n      emissiveMaterial(0, 255, 231);\n      box(s, s, s);\n    pop();\n  }\n}\n\nfunction dibujarPlataforma(p) {\n  push();\n    translate(p.x, p.y, p.z);\n    \n    // Rotar PI/8 (22.5 grados) hace que el cilindro de 8 caras \n    // se alinee con los ejes formando un cuadrado con esquinas biseladas.\n    rotateY(PI / 8); \n    \n    // Efecto Glass: Color con transparencia (Alpha = 120/140) + Alta especularidad\n    if (p.movil) { \n      fill(80, 150, 255, 140); \n      stroke(0, 255, 231, 200); \n    } else { \n      fill(120, 50, 220, 120); \n      stroke(200, 100, 255, 200); \n    }\n    \n    // Permite que la luz se refleje como si fuera cristal\n    specularMaterial(255, 255, 255);\n    shininess(100); \n    strokeWeight(2);\n    \n    // Al usar 8 lados (detailX = 8), creamos el octágono (Beveled Square).\n    // Dividir entre 1.8 el ancho ajusta el radio del cilindro para que coincida \n    // perfectamente con la caja de colisiones invisible de la física.\n    cylinder(p.ancho / 1.8, p.h, 8, 1);\n  pop();\n}\n\nfunction moverPlataforma(p) {\n  if (!p.movil) return;\n  p.fase += 0.025;\n  p.x = p.xBase + sin(p.fase) * p.amplitud;\n}\n\nfunction dibujarEstrellas() {\n  for (let e of estrellas) {\n    let b = e.brillo * (0.65 + 0.35 * sin(frameCount * e.velocidad));\n    stroke(b, b, min(b * 1.15, 255));\n    strokeWeight(e.tam);\n    point(e.x, e.y + jugY * 0.06, e.z);\n  }\n  noStroke();\n}\n\nfunction dibujarSuelo() {\n  push();\n    translate(0, lineaMuerteY - 1, 0);\n    rotateX(PI / 2);\n    noFill();\n    stroke(255, 51, 102); \n    strokeWeight(2);\n    for (let i = -1000; i <= 1000; i += 150) {\n      line(i, -1000, i, 1000);\n      line(-1000, i, 1000, i);\n    }\n  pop();\n}\n\nfunction dibujarBordes() {\n  let x1 = -400, x2 = 400, z1 = -300, z2 = 300;\n  let topY = jugY - 320, botY = lineaMuerteY + 80;\n  let esquinas = [\n    { x: x1, z: z1, dx:  1, dz:  1 }, { x: x2, z: z1, dx: -1, dz:  1 },\n    { x: x2, z: z2, dx: -1, dz: -1 }, { x: x1, z: z2, dx:  1, dz: -1 }\n  ];\n  for (let e of esquinas) {\n    for (let y = botY; y > topY; y -= 80) {\n      let alpha = map(y, botY, topY, 255, 0);\n      strokeWeight(map(y, botY, topY, 3, 0.5));\n      stroke(120, 150, 230, alpha); \n      line(e.x, y, e.z, e.x + e.dx * 28, y, e.z);\n      line(e.x, y, e.z, e.x, y, e.z + e.dz * 28);\n    }\n  }\n  noStroke();\n}\n\n// ── Partículas ────────────────────────────────────────────────────────────\nfunction spawnParticulas(x, y, z, col) {\n  for (let i = 0; i < 6; i++) {\n    let angulo = random(TWO_PI), vel = random(3, 8);\n    particulas.push({\n      x, y, z,\n      velX: cos(angulo) * vel, velY: random(-8, -3), velZ: sin(angulo) * vel,\n      radio: random(3, 7), vida: 35, max: 35,\n      r: col[0], g: col[1], b: col[2]\n    });\n  }\n}\n\nfunction dibujarParticulas() {\n  noStroke();\n  for (let i = particulas.length - 1; i >= 0; i--) {\n    let p = particulas[i];\n    p.velY += 0.45;\n    p.x += p.velX; p.y += p.velY; p.z += p.velZ;\n    if (--p.vida <= 0) { particulas.splice(i, 1); continue; }\n    let s = p.radio * (p.vida / p.max) * 2;\n    push();\n      translate(p.x, p.y, p.z);\n      rotateY(frameCount * 0.12 + i);\n      rotateX(frameCount * 0.08 + i);\n      emissiveMaterial(p.r, p.g, p.b);\n      box(s, s * 0.7, s);\n    pop();\n  }\n}\n\n// ── Generación de plataformas ─────────────────────────────────────────────\nfunction generarPlataforma() {\n  let altura = 150 - siguientePlataY;\n  let dif    = constrain(altura / 1000, 0, 1);\n  \n  // ASPECT RATIO 1: Un solo valor rige tanto el ancho como la profundidad\n  let tamBase  = lerp(180, 90, dif) + random(-10, 10);\n  let tamFinal = max(tamBase, 70); \n  \n  let movil  = dif > 0.35 && random() < 0.28;\n  let x      = random(-150, 150);\n  let z      = random(-110, 110);\n  \n  plataformas.push({\n    x, y: siguientePlataY, z, xBase: x,\n    ancho: tamFinal, h: PLAT_H, prof: tamFinal, // Aspect ratio 1:1 (Cuadrado)\n    movil, fase: random(TWO_PI), amplitud: movil ? random(50, 110) : 0,\n    visitada: false\n  });\n  siguientePlataY -= SEPARACION + random(5, 20);\n}\n\nfunction iniciarJuego() {\n  anguloCam = 0; clickIzquierdo = false; ultimoMouseX = 0;\n  puntos = 0; estela = []; particulas = [];\n  \n  document.getElementById('toast-container').innerHTML = '';\n  \n  let inicioY = 160, tope = inicioY - PLAT_H / 2;\n  jugX = 0; jugY = tope - RADIO; jugZ = 0;\n  velX = 0; velY = FUERZA_SALTO; velZ = 0;\n  alturaMax = jugY; lineaMuerteY = jugY + 480;\n  plataformas = [{ x:0, y:inicioY, z:0, xBase:0, ancho:220, h:PLAT_H, prof:220, movil:false, fase:0, amplitud:0, visitada:true }];\n  siguientePlataY = inicioY - SEPARACION;\n  for (let i = 0; i < 30; i++) generarPlataforma();\n}\n\n// ── Controles ─────────────────────────────────────────────────────────────\nfunction keyPressed() {\n  let esMov = keyCode === UP_ARROW || keyCode === DOWN_ARROW ||\n              keyCode === LEFT_ARROW || keyCode === RIGHT_ARROW ||\n              keyCode === 87 || keyCode === 83 ||\n              keyCode === 65 || keyCode === 68;\n              \n  if ((estado === 'inicio' || estado === 'gameover') && esMov) {\n    iniciarJuego(); \n    estado = 'jugando'; \n    cambiarPantalla('jugando');\n    return;\n  }\n  if (key === 'r' || key === 'R') { \n    iniciarJuego(); \n    estado = 'jugando'; \n    cambiarPantalla('jugando');\n  }\n}\nfunction mousePressed()  { if (mouseButton === LEFT)  { clickIzquierdo = true;  ultimoMouseX = mouseX; } }\nfunction mouseReleased() { if (mouseButton === LEFT)    clickIzquierdo = false; }"
        }
      }
    }
  }
}