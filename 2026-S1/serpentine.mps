      "c": {
        "index.js": {
          "k": 1,
          "c": "import * as THREE from 'three';\n\n// ══════════════════════════════════════════════════════\n//  SERPENTINE\n// ══════════════════════════════════════════════════════\n\nfunction marlenSetup() {\n  try {\n    console.log('[Serpentine] Iniciando...');\n\n    // 1. CSS\n    var cssLines = [\n\"*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\",\n\"\",\n\"    :root {\",\n\"      --cyan:   #00ffe7;\",\n\"      --purple: #7b2fff;\",\n\"      --gold:   #ffcc00;\",\n\"      --red:    #ff3366;\",\n\"      --bg:     #050510;\",\n\"      --panel:  rgba(5,5,30,0.88);\",\n\"      --border: rgba(0,255,231,0.25);\",\n\"      --font-display: 'Orbitron', monospace;\",\n\"      --font-mono:    'Share Tech Mono', monospace;\",\n\"      --easy-col:   #39ff6e;\",\n\"      --medium-col: #ffcc00;\",\n\"      --hard-col:   #ff3366;\",\n\"    }\",\n\"\",\n\"    html, body {\",\n\"      width: 100%; height: 100%;\",\n\"      background: var(--bg);\",\n\"      overflow: hidden;\",\n\"      font-family: var(--font-mono);\",\n\"      color: var(--cyan);\",\n\"      cursor: none;\",\n\"    }\",\n\"    #c {\",\n\"      display: block;\",\n\"      width: 100%; height: 100%;\",\n\"      position: fixed; top: 0; left: 0;\",\n\"    }\",\n\"\",\n\"    #loading-screen {\",\n\"      position: fixed;\",\n\"      inset: 0;\",\n\"      background: #050510;\",\n\"      display: flex;\",\n\"      flex-direction: column;\",\n\"      align-items: center;\",\n\"      justify-content: center;\",\n\"      z-index: 9999;\",\n\"      font-family: 'Orbitron', monospace;\",\n\"      color: #00ffe7;\",\n\"    }\",\n\"    #loading-screen h1 {\",\n\"      font-size: 44px;\",\n\"      letter-spacing: 5px;\",\n\"      margin-bottom: 8px;\",\n\"      text-shadow: 0 0 24px rgba(0, 255, 231, 0.55);\",\n\"    }\",\n\"    #loading-screen .loading-text {\",\n\"      letter-spacing: 4px;\",\n\"      animation: loadingPulse 1s infinite alternate;\",\n\"    }\",\n\"    #loading-screen .loading-spinner {\",\n\"      margin-top: 16px;\",\n\"      width: 40px;\",\n\"      height: 40px;\",\n\"      border-radius: 50%;\",\n\"      border: 3px solid rgba(0,255,231,0.1);\",\n\"      border-top-color: #00ffe7;\",\n\"      animation: spin 0.8s linear infinite;\",\n\"    }\",\n\"    @keyframes loadingPulse {\",\n\"      from { opacity: 0.3; }\",\n\"      to { opacity: 1; }\",\n\"    }\",\n\"    @keyframes spin {\",\n\"      to { transform: rotate(360deg); }\",\n\"    }\",\n\"\",\n\"    /* HUD */\",\n\"    #hud {\",\n\"      position: fixed; top: 0; left: 0; right: 0; bottom: 0;\",\n\"      pointer-events: none;\",\n\"      z-index: 10;\",\n\"    }\",\n\"    .panel {\",\n\"      background: var(--panel);\",\n\"      border: 1px solid var(--border);\",\n\"      -webkit-backdrop-filter: blur(12px);\",\n\"      backdrop-filter: blur(12px);\",\n\"      border-radius: 4px;\",\n\"    }\",\n\"\",\n\"    #score-panel { position: absolute; top: 20px; left: 20px; padding: 14px 22px; min-width: 160px; }\",\n\"    #score-panel .label { font-family: var(--font-display); font-size: 9px; letter-spacing: 3px; opacity: 0.5; text-transform: uppercase; }\",\n\"    #score-panel .value { font-family: var(--font-display); font-size: 32px; font-weight: 900; line-height: 1.1; text-shadow: 0 0 20px var(--cyan); transition: color 0.15s, text-shadow 0.15s; }\",\n\"    #score-panel .value.flash { color: var(--gold); text-shadow: 0 0 30px var(--gold); }\",\n\"    #score-panel .hi { font-size: 11px; opacity: 0.6; margin-top: 4px; }\",\n\"    #level-badge { display: inline-block; font-family: var(--font-display); font-size: 8px; letter-spacing: 2px; padding: 2px 8px; border-radius: 2px; margin-top: 6px; border: 1px solid currentColor; }\",\n\"\",\n\"    #info-panel { position: absolute; top: 20px; right: 20px; padding: 12px 18px; font-size: 11px; line-height: 1.8; text-align: right; opacity: 0.7; }\",\n\"    #info-panel span { color: var(--cyan); }\",\n\"\",\n\"    #settings-panel { position: absolute; bottom: 80px; right: 20px; padding: 16px 20px; width: 220px; pointer-events: all; font-size: 11px; transition: opacity 0.3s; }\",\n\"    #settings-panel.hidden { opacity: 0; pointer-events: none; }\",\n\"    #settings-panel h3 { font-family: var(--font-display); font-size: 9px; letter-spacing: 3px; margin-bottom: 12px; opacity: 0.6; }\",\n\"    .setting-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }\",\n\"    .setting-row label { opacity: 0.7; }\",\n\"    .setting-row input[type=range] { width: 90px; accent-color: var(--cyan); }\",\n\"    .setting-row select { background: transparent; border: 1px solid var(--border); color: var(--cyan); font-family: var(--font-mono); font-size: 10px; padding: 2px 4px; cursor: pointer; }\",\n\"    .setting-row select option { background: #0a0a2a; }\",\n\"\",\n\"    .screen { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; pointer-events: all; padding: 40px 50px; min-width: 340px; visibility: visible; transition: opacity 0.4s, transform 0.4s; }\",\n\"    .screen.hidden { opacity: 0; pointer-events: none; visibility: hidden; transform: translate(-50%, -48%); transition: none; }\",\n\"    .screen h1 { font-family: var(--font-display); font-size: 48px; font-weight: 900; letter-spacing: 6px; text-shadow: 0 0 40px var(--cyan), 0 0 80px var(--cyan); margin-bottom: 6px; }\",\n\"    .screen .subtitle { font-size: 11px; letter-spacing: 4px; opacity: 0.5; margin-bottom: 30px; }\",\n\"    .controls-list { text-align: left; font-size: 11px; line-height: 2.2; opacity: 0.65; margin-bottom: 28px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 12px 0; }\",\n\"    .controls-list span { color: var(--cyan); display: inline-block; width: 80px; }\",\n\"\",\n\"    .btn { display: inline-block; font-family: var(--font-display); font-size: 12px; letter-spacing: 3px; padding: 12px 32px; border: 1px solid var(--cyan); color: var(--cyan); background: transparent; cursor: pointer; transition: background 0.2s, box-shadow 0.2s; pointer-events: all; }\",\n\"    .btn:hover { background: rgba(0,255,231,0.1); box-shadow: 0 0 20px rgba(0,255,231,0.3); }\",\n\"    .btn + .btn { margin-left: 10px; }\",\n\"    .btn.secondary { border-color: rgba(0,255,231,0.3); color: rgba(0,255,231,0.45); font-size: 10px; padding: 10px 20px; }\",\n\"    .btn.secondary:hover { border-color: var(--cyan); color: var(--cyan); background: rgba(0,255,231,0.05); }\",\n\"\",\n\"    #level-select-screen { min-width: 440px; }\",\n\"    #level-select-screen h1 { font-size: 40px; }\",\n\"    .diff-cards { display: flex; gap: 12px; margin: 24px 0 28px; justify-content: center; }\",\n\"    .diff-card { flex: 1; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 16px 12px; cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s; background: rgba(5,5,30,0.5); pointer-events: all; min-width: 108px; }\",\n\"    .diff-card:hover { transform: translateY(-2px); }\",\n\"    .diff-card.selected { transform: translateY(-3px); }\",\n\"    .diff-card[data-diff=\\\"easy\\\"]   { border-color: rgba(57,255,110,0.35); }\",\n\"    .diff-card[data-diff=\\\"medium\\\"] { border-color: rgba(255,204,0,0.35); }\",\n\"    .diff-card[data-diff=\\\"hard\\\"]   { border-color: rgba(255,51,102,0.35); }\",\n\"    .diff-card[data-diff=\\\"easy\\\"].selected,   .diff-card[data-diff=\\\"easy\\\"]:hover   { border-color: var(--easy-col);   box-shadow: 0 0 18px rgba(57,255,110,0.3);  }\",\n\"    .diff-card[data-diff=\\\"medium\\\"].selected, .diff-card[data-diff=\\\"medium\\\"]:hover { border-color: var(--medium-col); box-shadow: 0 0 18px rgba(255,204,0,0.3);   }\",\n\"    .diff-card[data-diff=\\\"hard\\\"].selected,   .diff-card[data-diff=\\\"hard\\\"]:hover   { border-color: var(--hard-col);   box-shadow: 0 0 18px rgba(255,51,102,0.3);  }\",\n\"    .diff-card .diff-name { font-family: var(--font-display); font-size: 11px; letter-spacing: 3px; font-weight: 700; margin-bottom: 8px; }\",\n\"    .diff-card[data-diff=\\\"easy\\\"]   .diff-name { color: var(--easy-col); }\",\n\"    .diff-card[data-diff=\\\"medium\\\"] .diff-name { color: var(--medium-col); }\",\n\"    .diff-card[data-diff=\\\"hard\\\"]   .diff-name { color: var(--hard-col); }\",\n\"    .diff-card .diff-desc { font-size: 9px; opacity: 0.5; line-height: 1.7; letter-spacing: 1px; margin-bottom: 10px; }\",\n\"    .diff-card .diff-hi { font-size: 9px; letter-spacing: 2px; color: rgba(0,255,231,0.4); }\",\n\"    .diff-card .diff-hi strong { font-family: var(--font-display); font-size: 14px; display: block; margin-top: 2px; opacity: 1; }\",\n\"    .diff-card[data-diff=\\\"easy\\\"]   .diff-hi strong { color: var(--easy-col); }\",\n\"    .diff-card[data-diff=\\\"medium\\\"] .diff-hi strong { color: var(--medium-col); }\",\n\"    .diff-card[data-diff=\\\"hard\\\"]   .diff-hi strong { color: var(--hard-col); }\",\n\"\",\n\"    #game-over-screen h1 { color: var(--red); text-shadow: 0 0 40px var(--red); }\",\n\"    #game-over-screen .final-score { font-family: var(--font-display); font-size: 56px; font-weight: 900; margin: 10px 0 2px; text-shadow: 0 0 20px var(--cyan); }\",\n\"    #game-over-screen .hi-label { font-size: 11px; opacity: 0.5; margin-bottom: 8px; }\",\n\"    #new-record-badge { display: inline-block; font-family: var(--font-display); font-size: 10px; letter-spacing: 3px; padding: 4px 14px; border: 1px solid var(--gold); color: var(--gold); text-shadow: 0 0 10px var(--gold); margin-bottom: 14px; animation: pulseGold 1s infinite alternate; }\",\n\"    #new-record-badge.hidden { display: none; }\",\n\"    @keyframes pulseGold { from { box-shadow: 0 0 5px rgba(255,204,0,0.3); } to { box-shadow: 0 0 18px rgba(255,204,0,0.7); } }\",\n\"    .session-stats { display: flex; justify-content: center; gap: 24px; margin-bottom: 14px; font-size: 10px; opacity: 0.6; letter-spacing: 1px; }\",\n\"    .session-stats .stat-val { font-family: var(--font-display); font-size: 15px; display: block; color: var(--cyan); opacity: 1; margin-bottom: 2px; }\",\n\"    #score-history { margin: 0 0 20px; font-size: 10px; }\",\n\"    #score-history .hist-title { font-family: var(--font-display); font-size: 8px; letter-spacing: 3px; margin-bottom: 6px; opacity: 0.4; }\",\n\"    #score-history table { width: 100%; border-collapse: collapse; }\",\n\"    #score-history td { padding: 3px 8px; text-align: center; opacity: 0.55; }\",\n\"    #score-history tr:first-child td { color: var(--gold); opacity: 1; }\",\n\"\",\n\"    #pause-badge { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-family: var(--font-display); font-size: 14px; letter-spacing: 8px; padding: 10px 24px; border: 1px solid var(--border); background: var(--panel); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); transition: opacity 0.3s; }\",\n\"    #pause-badge.hidden { opacity: 0; pointer-events: none; }\",\n\"\",\n\"    #debug-overlay { position: absolute; bottom: 20px; left: 20px; font-size: 10px; line-height: 1.7; opacity: 0.5; pointer-events: none; }\",\n\"    #debug-overlay.hidden { display: none; }\",\n\"\",\n\"    #speed-bar { position: absolute; bottom: 64px; left: 50%; transform: translateX(-50%); display: flex; gap: 3px; align-items: center; }\",\n\"    .speed-pip { width: 6px; height: 16px; border: 1px solid rgba(0,255,231,0.3); border-radius: 2px; transition: background 0.3s; }\",\n\"    .speed-pip.active { background: var(--cyan); box-shadow: 0 0 6px var(--cyan); }\",\n\"\",\n\"    #cursor { position: fixed; width: 12px; height: 12px; border: 1px solid var(--cyan); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%, -50%); box-shadow: 0 0 8px var(--cyan); }\",\n\"\",\n\"    #wall-badge { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); font-size: 9px; letter-spacing: 3px; opacity: 0.5; padding: 5px 12px; border: 1px solid var(--border); background: var(--panel); }\",\n\"\",\n\"    #toast-container { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -90px); pointer-events: none; z-index: 20; display: flex; flex-direction: column; align-items: center; gap: 8px; }\",\n\"    .toast { font-family: var(--font-display); font-size: 11px; letter-spacing: 4px; padding: 8px 20px; border: 1px solid var(--gold); color: var(--gold); background: rgba(5,5,30,0.92); -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px); text-shadow: 0 0 10px var(--gold); animation: toastIn 0.3s ease, toastOut 0.4s ease 1.8s forwards; border-radius: 2px; }\",\n\"    @keyframes toastIn  { from { opacity:0; transform:translateY(10px) scale(0.9); } to { opacity:1; transform:translateY(0) scale(1); } }\",\n\"    @keyframes toastOut { from { opacity:1; } to { opacity:0; transform:translateY(-10px); } }\",\n\"\",\n\"    #score-popup { position: absolute; font-family: var(--font-display); font-size: 18px; font-weight: 900; color: var(--gold); text-shadow: 0 0 12px var(--gold); pointer-events: none; opacity: 0; letter-spacing: 2px; }\",\n\"\",\n\"    #joystick-zone { visibility: hidden; opacity: 0; position: fixed; bottom: 60px; left: 30px; width: 130px; height: 130px; pointer-events: none; z-index: 15; transition: opacity 0.25s, visibility 0.25s; }\",\n\"    #joystick-zone.visible { visibility: visible; opacity: 1; pointer-events: all; }\",\n\"    #joystick-base { width: 100%; height: 100%; border-radius: 50%; border: 2px solid rgba(0,255,231,0.3); background: rgba(0,255,231,0.05); position: relative; }\",\n\"    #joystick-knob { width: 48px; height: 48px; border-radius: 50%; background: rgba(0,255,231,0.2); border: 2px solid var(--cyan); box-shadow: 0 0 14px rgba(0,255,231,0.45); position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); transition: transform 0.04s; }\",\n\"\",\n\"    #ctrl-toggle {\",\n\"      position: fixed;\",\n\"      bottom: 20px; right: 20px;\",\n\"      pointer-events: all;\",\n\"      z-index: 20;\",\n\"      display: flex;\",\n\"      align-items: center;\",\n\"      gap: 7px;\",\n\"      padding: 8px 14px;\",\n\"      background: var(--panel);\",\n\"      border: 1px solid var(--border);\",\n\"      -webkit-backdrop-filter: blur(10px);\",\n\"      backdrop-filter: blur(10px);\",\n\"      border-radius: 20px;\",\n\"      cursor: pointer;\",\n\"      font-family: var(--font-display);\",\n\"      font-size: 9px;\",\n\"      letter-spacing: 2px;\",\n\"      color: rgba(0,255,231,0.55);\",\n\"      transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;\",\n\"      -webkit-user-select: none;\",\n\"      user-select: none;\",\n\"      outline: none;\",\n\"    }\",\n\"    #ctrl-toggle:focus-visible { outline: 2px solid var(--cyan); outline-offset: 3px; }\",\n\"    #ctrl-toggle:hover { border-color: var(--cyan); color: var(--cyan); box-shadow: 0 0 14px rgba(0,255,231,0.2); }\",\n\"    #ctrl-toggle.active-joystick { border-color: rgba(0,255,231,0.6); color: var(--cyan); box-shadow: 0 0 10px rgba(0,255,231,0.15); }\",\n\"    #ctrl-toggle.active-swipe { border-color: rgba(123,47,255,0.6); color: var(--purple); box-shadow: 0 0 10px rgba(123,47,255,0.2); }\",\n\"    #ctrl-toggle .ctrl-icon { font-size: 14px; line-height: 1; }\",\n\"    #ctrl-toggle .ctrl-label { letter-spacing: 2px; }\",\n\"\",\n\"    body.touch-mode #cursor { display: none; }\",\n\"    body.touch-mode { cursor: auto; }\",\n\"\",\n\"    #no-webgl { display: none; position: fixed; inset: 0; background: var(--bg); flex-direction: column; align-items: center; justify-content: center; font-family: var(--font-display); font-size: 18px; text-align: center; gap: 12px; }\",\n\"    #no-webgl.visible { display: flex; }\",\n\"\",\n\"    @keyframes pulseGlow { 0%,100% { text-shadow: 0 0 20px var(--cyan); } 50% { text-shadow: 0 0 50px var(--cyan), 0 0 100px var(--cyan); } }\",\n\"    .glow-pulse { animation: pulseGlow 2s infinite; }\",\n\"\",\n\"    @media (max-width: 600px) {\",\n\"      .screen, #level-select-screen { min-width: 92vw; padding: 28px 16px; }\",\n\"      .screen h1, #level-select-screen h1 { font-size: 30px; }\",\n\"      .diff-cards { gap: 8px; }\",\n\"      .diff-card { padding: 12px 8px; min-width: 0; }\",\n\"      #settings-panel { width: 180px; }\",\n\"    }\",\n\"    @media (max-width: 380px) {\",\n\"      .diff-cards { flex-direction: column; align-items: center; }\",\n\"      .diff-card { width: 80%; }\",\n\"    }\"\n    ];\n    var style = document.createElement('style');\n    style.textContent = cssLines.join('\\n');\n    document.head.appendChild(style);\n\n    // 2. HTML\n    var htmlLines = [\n\"<div id=\\\"loading-screen\\\">\",\n\"  <h1>SERPENTINE</h1>\",\n\"  <div class=\\\"loading-text\\\">CARGANDO...</div>\",\n\"  <div class=\\\"loading-spinner\\\" aria-hidden=\\\"true\\\"></div>\",\n\"</div>\",\n\"\",\n\"<div id=\\\"no-webgl\\\">\",\n\"  <div>⚠ Se requiere WebGL</div>\",\n\"  <div style=\\\"font-size:12px;opacity:0.6\\\">Activa la aceleración de hardware en tu navegador.</div>\",\n\"</div>\",\n\"\",\n\"<canvas id=\\\"c\\\"></canvas>\",\n\"<div id=\\\"cursor\\\"></div>\",\n\"\",\n\"<div id=\\\"joystick-zone\\\" aria-hidden=\\\"true\\\">\",\n\"  <div id=\\\"joystick-base\\\"><div id=\\\"joystick-knob\\\"></div></div>\",\n\"</div>\",\n\"\",\n\"<button id=\\\"ctrl-toggle\\\" type=\\\"button\\\" aria-label=\\\"Cambiar modo de control\\\">\",\n\"  <span class=\\\"ctrl-icon\\\" id=\\\"ctrl-icon\\\">🕹</span>\",\n\"  <span class=\\\"ctrl-label\\\" id=\\\"ctrl-label\\\">JOYSTICK</span>\",\n\"</button>\",\n\"\",\n\"<div id=\\\"hud\\\">\",\n\"\",\n\"  <div id=\\\"score-panel\\\" class=\\\"panel\\\">\",\n\"    <div class=\\\"label\\\">Puntos</div>\",\n\"    <div class=\\\"value\\\" id=\\\"score-val\\\">0</div>\",\n\"    <div class=\\\"hi\\\">REC <span id=\\\"hi-val\\\">0</span></div>\",\n\"    <div id=\\\"level-badge\\\">MEDIO</div>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"info-panel\\\" class=\\\"panel\\\">\",\n\"    <div>LEN <span id=\\\"len-val\\\">1</span></div>\",\n\"    <div>VEL <span id=\\\"spd-val\\\">10.0</span></div>\",\n\"    <div id=\\\"wall-mode-info\\\">PAREDES</div>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"wall-badge\\\">PAREDES</div>\",\n\"\",\n\"  <div id=\\\"speed-bar\\\">\",\n\"    <div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div>\",\n\"    <div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div>\",\n\"    <div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div><div class=\\\"speed-pip\\\"></div>\",\n\"    <div class=\\\"speed-pip\\\"></div>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"settings-panel\\\" class=\\\"panel hidden\\\">\",\n\"    <h3>⚙ Ajustes</h3>\",\n\"    <div class=\\\"setting-row\\\"><label for=\\\"quality-select\\\">Calidad</label>\",\n\"      <select id=\\\"quality-select\\\">\",\n\"        <option value=\\\"low\\\">Baja</option>\",\n\"        <option value=\\\"med\\\" selected>Media</option>\",\n\"        <option value=\\\"high\\\">Alta</option>\",\n\"      </select>\",\n\"    </div>\",\n\"    <div class=\\\"setting-row\\\"><label for=\\\"particle-count\\\">Partículas</label><input type=\\\"range\\\" id=\\\"particle-count\\\" min=\\\"5\\\" max=\\\"60\\\" value=\\\"30\\\" step=\\\"5\\\"></div>\",\n\"    <div class=\\\"setting-row\\\"><label for=\\\"smooth-slider\\\">Suavizado</label><input type=\\\"range\\\" id=\\\"smooth-slider\\\"   min=\\\"1\\\" max=\\\"20\\\" value=\\\"8\\\"  step=\\\"1\\\"></div>\",\n\"    <div class=\\\"setting-row\\\"><label for=\\\"speed-slider\\\">Velocidad</label>    <input type=\\\"range\\\" id=\\\"speed-slider\\\"    min=\\\"5\\\" max=\\\"25\\\" value=\\\"10\\\" step=\\\"1\\\"></div>\",\n\"    <div class=\\\"setting-row\\\"><label for=\\\"spacing-slider\\\">Espaciado</label>  <input type=\\\"range\\\" id=\\\"spacing-slider\\\"  min=\\\"0.6\\\" max=\\\"1.4\\\" value=\\\"0.9\\\" step=\\\"0.1\\\"></div>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"pause-badge\\\" class=\\\"hidden\\\">PAUSA</div>\",\n\"\",\n\"  <div id=\\\"toast-container\\\" role=\\\"status\\\" aria-live=\\\"polite\\\" aria-atomic=\\\"false\\\"></div>\",\n\"  <div id=\\\"score-popup\\\" aria-hidden=\\\"true\\\"></div>\",\n\"\",\n\"  <div id=\\\"level-select-screen\\\" class=\\\"screen panel\\\">\",\n\"    <h1 class=\\\"glow-pulse\\\">SERPENTINE</h1>\",\n\"    <div class=\\\"subtitle\\\">3D · SERPIENTE POINTER</div>\",\n\"    <div class=\\\"diff-cards\\\">\",\n\"      <div class=\\\"diff-card\\\" data-diff=\\\"easy\\\" role=\\\"button\\\" tabindex=\\\"0\\\" aria-label=\\\"Dificultad fácil\\\">\",\n\"        <div class=\\\"diff-name\\\">FÁCIL</div>\",\n\"        <div class=\\\"diff-desc\\\">Envolver · Lento<br>Relajado</div>\",\n\"        <div class=\\\"diff-hi\\\">MEJOR<strong id=\\\"hi-easy\\\">0</strong></div>\",\n\"      </div>\",\n\"      <div class=\\\"diff-card\\\" data-diff=\\\"medium\\\" role=\\\"button\\\" tabindex=\\\"0\\\" aria-label=\\\"Dificultad media\\\">\",\n\"        <div class=\\\"diff-name\\\">MEDIO</div>\",\n\"        <div class=\\\"diff-desc\\\">Paredes · Clásico<br>Equilibrado</div>\",\n\"        <div class=\\\"diff-hi\\\">MEJOR<strong id=\\\"hi-medium\\\">0</strong></div>\",\n\"      </div>\",\n\"      <div class=\\\"diff-card\\\" data-diff=\\\"hard\\\" role=\\\"button\\\" tabindex=\\\"0\\\" aria-label=\\\"Dificultad difícil\\\">\",\n\"        <div class=\\\"diff-name\\\">DIFÍCIL</div>\",\n\"        <div class=\\\"diff-desc\\\">Rápido · Ajustado<br>Sin Piedad</div>\",\n\"        <div class=\\\"diff-hi\\\">MEJOR<strong id=\\\"hi-hard\\\">0</strong></div>\",\n\"      </div>\",\n\"    </div>\",\n\"    <button class=\\\"btn\\\" id=\\\"diff-play-btn\\\" type=\\\"button\\\">JUGAR</button>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"start-screen\\\" class=\\\"screen panel hidden\\\">\",\n\"    <h1 class=\\\"glow-pulse\\\">LISTO</h1>\",\n\"    <div class=\\\"subtitle\\\" id=\\\"start-diff-label\\\">MEDIO · PAREDES</div>\",\n\"    <div class=\\\"controls-list\\\">\",\n\"      <div><span>RATÓN</span> Guiar serpiente</div>\",\n\"      <div><span>WASD/↑↓←→</span> Teclado</div>\",\n\"      <div><span>ESPACIO</span> Pausa/Reanudar</div>\",\n\"      <div><span>R</span> Reiniciar</div>\",\n\"      <div><span>T</span> Alternar paredes</div>\",\n\"      <div><span>M</span> Modo control</div>\",\n\"      <div><span>ESC</span> Ajustes</div>\",\n\"      <div><span>` (tilde)</span> Debug</div>\",\n\"    </div>\",\n\"    <button class=\\\"btn\\\" id=\\\"start-btn\\\" type=\\\"button\\\">EMPEZAR</button>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"game-over-screen\\\" class=\\\"screen panel hidden\\\">\",\n\"    <h1>ELIMINADO</h1>\",\n\"    <div class=\\\"final-score\\\" id=\\\"final-score\\\">0</div>\",\n\"    <div class=\\\"hi-label\\\">RÉCORD: <span id=\\\"final-hi\\\">0</span></div>\",\n\"    <div id=\\\"new-record-badge\\\" class=\\\"hidden\\\">★ NUEVO RÉCORD ★</div>\",\n\"    <div class=\\\"session-stats\\\">\",\n\"      <div><span class=\\\"stat-val\\\" id=\\\"stat-time\\\">0:00</span>TIEMPO</div>\",\n\"      <div><span class=\\\"stat-val\\\" id=\\\"stat-food\\\">0</span>COMIDA</div>\",\n\"      <div><span class=\\\"stat-val\\\" id=\\\"stat-len\\\">0</span>LEN MÁX</div>\",\n\"    </div>\",\n\"    <div id=\\\"score-history\\\">\",\n\"      <div class=\\\"hist-title\\\">PARTIDAS RECIENTES</div>\",\n\"      <table id=\\\"history-table\\\"><tbody></tbody></table>\",\n\"    </div>\",\n\"    <button class=\\\"btn\\\"           id=\\\"restart-btn\\\" type=\\\"button\\\">REINTENTAR</button>\",\n\"    <button class=\\\"btn secondary\\\" id=\\\"menu-btn\\\"    type=\\\"button\\\">MENÚ</button>\",\n\"  </div>\",\n\"\",\n\"  <div id=\\\"debug-overlay\\\" class=\\\"hidden\\\">\",\n\"    <div>CAB: <span id=\\\"dbg-head\\\">—</span></div>\",\n\"    <div>SEG: <span id=\\\"dbg-segs\\\">—</span></div>\",\n\"    <div>COM: <span id=\\\"dbg-food\\\">—</span></div>\",\n\"    <div>FPS: <span id=\\\"dbg-fps\\\">—</span></div>\",\n\"    <div>ESP: <span id=\\\"dbg-spacing\\\">—</span></div>\",\n\"    <div>COL: <span id=\\\"dbg-coll\\\">ninguna</span></div>\",\n\"  </div>\",\n\"\",\n\"</div>\"\n    ];\n    document.body.innerHTML = htmlLines.join('\\n');\n\n    console.log('[Serpentine] HTML inyectado, iniciando juego...');\n    initSerpentine();\n\n  } catch (e) {\n    console.error('[Serpentine] Error de configuración:', e);\n    document.body.innerHTML = '<div style=\"color:#00ffe7;font-family:monospace;padding:20px;\">Error: ' + e.message + '</div>';\n  }\n}\n\nfunction showFallback(title, hint) {\n  try {\n    var fb = document.getElementById('no-webgl');\n    if (fb) {\n      var t = fb.querySelector('div:first-child');\n      var h = fb.querySelector('div:nth-child(2)');\n      if (t) t.textContent = '⚠ ' + (title || 'Motor 3D no disponible');\n      if (h) h.textContent = hint || 'Revisa extensiones de privacidad y recarga.';\n      fb.classList.add('visible');\n    }\n    var c = document.getElementById('c');\n    if (c) c.style.display = 'none';\n    var ls = document.getElementById('loading-screen');\n    if (ls) ls.style.display = 'none';\n  } catch(e) {}\n}\n\nif (document.readyState === 'loading') {\n  document.addEventListener('DOMContentLoaded', marlenSetup);\n} else {\n  marlenSetup();\n}\n\n// ══════════════════════════════════════════════════════\n//  LÓGICA DEL JUEGO\n// ══════════════════════════════════════════════════════\n\nfunction initSerpentine() {\n  if (!window.THREE && typeof THREE === 'undefined') {\n    showFallback('Motor 3D no disponible', 'Revisa extensiones de privacidad y recarga.');\n    return;\n  }\n\nconst CACHE = {\n  PFX: 'serpentine_',\n  get(key, fallback) {\n    try {\n      const raw = localStorage.getItem(this.PFX + key);\n      if (raw === null) return fallback !== undefined ? fallback : null;\n      return JSON.parse(raw);\n    } catch(e) { return fallback !== undefined ? fallback : null; }\n  },\n  set(key, val) {\n    try { localStorage.setItem(this.PFX + key, JSON.stringify(val)); } catch(e) {}\n  },\n  saveRun(diff, score, meta) {\n    const hi   = this.get('hi',      { easy: 0, medium: 0, hard: 0 });\n    const hist = this.get('history', { easy: [], medium: [], hard: [] });\n    const isNew = score > (hi[diff] || 0);\n    if (isNew) hi[diff] = score;\n    if (!hist[diff]) hist[diff] = [];\n    hist[diff].unshift({ score, time: meta.time, food: meta.food, len: meta.len });\n    if (hist[diff].length > 5) hist[diff].length = 5;\n    const games = this.get('games', 0);\n    this.set('hi',       hi);\n    this.set('history',  hist);\n    this.set('games',    games + 1);\n    this.set('last_diff', diff);\n    return { isNew, hiScores: hi };\n  }\n};\n\nconst DIFF = {\n  easy: {\n    label: 'FÁCIL',   color: '#39ff6e',\n    initialSpeed: 7, wallsEnabled: false,\n    scorePerFood: 10, speedIncreasePerFood: 0.04,\n    selfCollisionFrom: 12, boardSize: 22, growthPerFood: 3,\n    descLine: 'FÁCIL · ENVOLVER',\n  },\n  medium: {\n    label: 'MEDIO',   color: '#ffcc00',\n    initialSpeed: 10, wallsEnabled: true,\n    scorePerFood: 15, speedIncreasePerFood: 0.1,\n    selfCollisionFrom: 8, boardSize: 20, growthPerFood: 3,\n    descLine: 'MEDIO · PAREDES',\n  },\n  hard: {\n    label: 'DIFÍCIL', color: '#ff3366',\n    initialSpeed: 15, wallsEnabled: true,\n    scorePerFood: 25, speedIncreasePerFood: 0.2,\n    selfCollisionFrom: 5, boardSize: 18, growthPerFood: 4,\n    descLine: 'DIFÍCIL · SIN PIEDAD',\n  },\n};\n\nconst MILESTONES = [\n  { score: 50,   msg: '⚡ CALENTANDO'      },\n  { score: 100,  msg: '🎯 CENTURIÓN'       },\n  { score: 250,  msg: '🔥 SEÑOR SERPIENTE' },\n  { score: 500,  msg: '💀 DEPREDADOR'      },\n  { score: 1000, msg: '★  LEGENDARIO  ★'   },\n];\n\nconst CONFIG = {\n  boardSize: 20, boardY: 0,\n  initialSpeed: 10, segmentSpacing: 0.9, segmentCountLimit: 500,\n  growthPerFood: 3, headRadius: 0.45, segRadius: 0.36, foodRadius: 0.5,\n  interactionSmoothing: 8, keyMoveSpeed: 14,\n  camHeight: 28, camDistance: 10, camFOV: 55, camFollowStrength: 0.04,\n  particleCount: 35, particleLife: 0.8, particleSpeed: 10,\n  scorePerFood: 15, speedIncreasePerFood: 0.1, selfCollisionFrom: 8,\n  quality: 'med', wallsEnabled: true, debugVisible: false,\n};\n\nlet currentDifficulty = (() => {\n  const last = CACHE.get('last_diff', 'medium');\n  return (last in DIFF) ? last : 'medium';\n})();\n\nfunction refreshDiffCards() {\n  const hi = CACHE.get('hi', { easy: 0, medium: 0, hard: 0 });\n  document.getElementById('hi-easy').textContent   = hi.easy   || 0;\n  document.getElementById('hi-medium').textContent = hi.medium || 0;\n  document.getElementById('hi-hard').textContent   = hi.hard   || 0;\n  document.querySelectorAll('.diff-card').forEach(c => c.classList.remove('selected'));\n  const sel = document.querySelector(`.diff-card[data-diff=\"${currentDifficulty}\"]`);\n  if (sel) sel.classList.add('selected');\n}\nrefreshDiffCards();\n\nconst savedSettings = CACHE.get('settings', { quality: 'med' });\nif (savedSettings.quality) document.getElementById('quality-select').value = savedSettings.quality;\n\nconst hasWebGL = (() => {\n  try {\n    const c = document.createElement('canvas');\n    return !!(c.getContext('webgl') || c.getContext('experimental-webgl'));\n  } catch(e) { return false; }\n})();\n\nif (!hasWebGL) {\n  document.getElementById('no-webgl').classList.add('visible');\n  document.getElementById('c').style.display = 'none';\n  document.getElementById('loading-screen').style.display = 'none';\n  return;\n}\n\nconst canvas   = document.getElementById('c');\nconst renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });\nrenderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));\nrenderer.setSize(window.innerWidth, window.innerHeight);\nrenderer.shadowMap.enabled   = true;\nrenderer.shadowMap.type      = THREE.PCFShadowMap; \n\nrenderer.outputColorSpace    = THREE.SRGBColorSpace; \nrenderer.toneMapping          = THREE.ACESFilmicToneMapping;\nrenderer.toneMappingExposure  = 1.1;\n\nconst scene = new THREE.Scene();\nscene.background = new THREE.Color(0x020207);\nscene.fog = new THREE.FogExp2(0x020207, 0.025);\n\nconst camera = new THREE.PerspectiveCamera(CONFIG.camFOV, window.innerWidth / window.innerHeight, 0.1, 200);\ncamera.position.set(0, CONFIG.camHeight, CONFIG.camDistance);\ncamera.lookAt(0, 0, 0);\n\nconst ambientLight = new THREE.AmbientLight(0x08081a, 1.2);\nscene.add(ambientLight);\n\nconst dirLight = new THREE.DirectionalLight(0x3366ff, 2.5);\ndirLight.position.set(15, 35, 15);\ndirLight.castShadow = true;\ndirLight.shadow.mapSize.set(1024, 1024);\nscene.add(dirLight);\n\nconst rimLight1 = new THREE.PointLight(0x00ffe7, 45, 50); rimLight1.position.set(-15, 6, -15); scene.add(rimLight1);\nconst rimLight2 = new THREE.PointLight(0x7b2fff, 35, 50); rimLight2.position.set( 15, 6,  15); scene.add(rimLight2);\n\nlet gridGroup = new THREE.Group();\nscene.add(gridGroup);\n\nfunction buildGrid() {\n  gridGroup.clear();\n  const B = CONFIG.boardSize;\n  const step = 1; \n\n  const lm = new THREE.LineDashedMaterial({ \n    color: 0x0c2cb0, \n    transparent: true, \n    opacity: 0.65,\n    dashSize: 0.2,\n    gapSize: 0.1\n  });\n  const am = new THREE.LineDashedMaterial({ \n    color: 0x00a2ff, \n    transparent: true, \n    opacity: 0.85,\n    dashSize: 0.4,\n    gapSize: 0.1\n  });\n  \n  for (let x = -B; x <= B; x += step) {\n    const geo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(x,0,-B), new THREE.Vector3(x,0,B)]);\n    const line = new THREE.Line(geo, (Math.round(x)%5===0)?am:lm);\n    line.computeLineDistances(); \n    gridGroup.add(line);\n  }\n  for (let z = -B; z <= B; z += step) {\n    const geo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-B,0,z), new THREE.Vector3(B,0,z)]);\n    const line = new THREE.Line(geo, (Math.round(z)%5===0)?am:lm);\n    line.computeLineDistances();\n    gridGroup.add(line);\n  }\n  \n  const neonOuterMat = new THREE.LineBasicMaterial({ \n    color: 0x00ffe7, \n    transparent: true, \n    opacity: 0.95,\n    blending: THREE.AdditiveBlending \n  });\n  gridGroup.add(new THREE.Line(\n    new THREE.BufferGeometry().setFromPoints([\n      new THREE.Vector3(-B,0.02,-B),new THREE.Vector3(B,0.02,-B),\n      new THREE.Vector3(B,0.02,B),  new THREE.Vector3(-B,0.02,B),\n      new THREE.Vector3(-B,0.02,-B)\n    ]),\n    neonOuterMat\n  ));\n\n  const ground = new THREE.Mesh(\n    new THREE.PlaneGeometry(B*2, B*2),\n    new THREE.MeshStandardMaterial({ color: 0x010103, roughness: 0.35, metalness: 0.85 })\n  );\n  ground.rotation.x = -Math.PI / 2;\n  ground.receiveShadow = true;\n  gridGroup.add(ground);\n}\nbuildGrid();\n\nconst wallGroup = new THREE.Group();\nscene.add(wallGroup);\nfunction buildWalls() {\n  wallGroup.clear();\n  if (!CONFIG.wallsEnabled) return;\n  const B = CONFIG.boardSize, h = 1.2;\n  const mat = new THREE.MeshStandardMaterial({ color: 0x0a2040, emissive: 0x002244, emissiveIntensity: 2.0, transparent: true, opacity: 0.4, roughness: 0.4 });\n  [\n    { sx: B*2+0.2, sz: 0.2, px: 0, pz: -B },\n    { sx: B*2+0.2, sz: 0.2, px: 0, pz:  B },\n    { sx: 0.2, sz: B*2+0.2, px: -B, pz: 0 },\n    { sx: 0.2, sz: B*2+0.2, px:  B, pz: 0 },\n  ].forEach(c => {\n    const m = new THREE.Mesh(new THREE.BoxGeometry(c.sx, h, c.sz), mat);\n    m.position.set(c.px, h/2, c.pz);\n    wallGroup.add(m);\n  });\n}\nbuildWalls();\n\nconst headGeo  = new THREE.SphereGeometry(CONFIG.headRadius, 16, 12);\n// 💡 MODIFICADO: Emissive exponencial súper alto para provocar el destello atómico (Neon Glow)\nconst headMat  = new THREE.MeshStandardMaterial({ color: 0x00ffe7, emissive: 0x00ffe7, emissiveIntensity: 6.0, roughness: 0.05, metalness: 0.2 });\nconst headMesh = new THREE.Mesh(headGeo, headMat);\nheadMesh.castShadow = true;\nscene.add(headMesh);\n\nconst headLight = new THREE.PointLight(0x00ffe7, 25, 10);\nscene.add(headLight);\n// 💡 MODIFICADO: Ojos hiper-emisivos\nconst eyeMat = new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0xffffff, emissiveIntensity: 8.0 });\nconst eyeL = new THREE.Mesh(new THREE.SphereGeometry(0.1, 8, 6), eyeMat);\nconst eyeR = new THREE.Mesh(new THREE.SphereGeometry(0.1, 8, 6), eyeMat);\neyeL.position.set(-0.2, 0.2, 0.35); eyeR.position.set(0.2, 0.2, 0.35);\nheadMesh.add(eyeL); headMesh.add(eyeR);\n\nconst MAX_SEGS  = CONFIG.segmentCountLimit;\n// 💡 MODIFICADO: Incrementado el emisor de los eslabones del cuerpo para que parezcan barras de neón líquidas\nconst bodyMesh  = new THREE.InstancedMesh(\n  new THREE.SphereGeometry(CONFIG.segRadius, 10, 8),\n  new THREE.MeshStandardMaterial({ color: 0x7b2fff, emissive: 0x5a00ff, emissiveIntensity: 4.5, roughness: 0.1, metalness: 0.4 }),\n  MAX_SEGS\n);\nbodyMesh.castShadow = true;\nbodyMesh.count = 0;\nscene.add(bodyMesh);\nconst _dummy = new THREE.Object3D();\nconst _color  = new THREE.Color();\nfunction updateBodyInstances(segs) {\n  const n = Math.min(segs.length, MAX_SEGS);\n  bodyMesh.count = n;\n  for (let i = 0; i < n; i++) {\n    const t = i / Math.max(n - 1, 1);\n    _dummy.position.copy(segs[i]);\n    _dummy.scale.setScalar(1 - t * 0.25);\n    _dummy.updateMatrix();\n    bodyMesh.setMatrixAt(i, _dummy.matrix);\n    _color.setRGB(0.0 + t * 0.47, 0.8 - t * 0.6, 0.9 - t * 0.1);\n    bodyMesh.setColorAt(i, _color);\n  }\n  bodyMesh.instanceMatrix.needsUpdate = true;\n  if (bodyMesh.instanceColor) bodyMesh.instanceColor.needsUpdate = true;\n}\n\n// 💡 MODIFICADO: Ítem de comida con auto-iluminación dorada desbordante (Glow puro)\nconst foodMesh  = new THREE.Mesh(new THREE.OctahedronGeometry(CONFIG.foodRadius, 0), new THREE.MeshStandardMaterial({ color: 0xffcc00, emissive: 0xffcc00, emissiveIntensity: 7.0, roughness: 0.05, metalness: 0.5 }));\nfoodMesh.castShadow = true;\nscene.add(foodMesh);\n\nconst foodLight = new THREE.PointLight(0xffcc00, 30, 12);\nscene.add(foodLight);\n\nconst MAX_PARTICLES    = 120;\nconst particleGeo      = new THREE.BufferGeometry();\nconst particlePositions = new Float32Array(MAX_PARTICLES * 3);\nparticleGeo.setAttribute('position', new THREE.BufferAttribute(particlePositions, 3));\n// 💡 MODIFICADO: Puntos con mezcla aditiva activa (`blending: THREE.AdditiveBlending`) para estallar en destellos radioactivos\nconst particleMat = new THREE.PointsMaterial({ \n  color: 0xffcc00, \n  size: 0.35, \n  transparent: true, \n  opacity: 1.0, \n  depthWrite: false, \n  blending: THREE.AdditiveBlending \n});\nconst particleSystem = new THREE.Points(particleGeo, particleMat);\nscene.add(particleSystem);\nconst particles = [];\nfunction spawnParticles(pos) {\n  for (let i = 0; i < CONFIG.particleCount; i++) {\n    const angle = Math.random() * Math.PI * 2;\n    const elev  = (Math.random() - 0.5) * Math.PI;\n    const spd   = (0.5 + Math.random()) * CONFIG.particleSpeed;\n    particles.push({ pos: pos.clone(), vel: new THREE.Vector3(Math.cos(angle)*Math.cos(elev)*spd, Math.abs(Math.sin(elev))*spd, Math.sin(angle)*Math.cos(elev)*spd), life: 1.0 });\n  }\n}\nfunction updateParticles(dt) {\n  for (let i = particles.length - 1; i >= 0; i--) {\n    const p = particles[i];\n    p.life -= dt / CONFIG.particleLife;\n    p.vel.y -= 9.8 * dt;\n    p.pos.addScaledVector(p.vel, dt);\n    if (p.life <= 0) particles.splice(i, 1);\n  }\n  const count = Math.min(particles.length, MAX_PARTICLES);\n  for (let i = 0; i < count; i++) {\n    particlePositions[i*3]   = particles[i].pos.x;\n    particlePositions[i*3+1] = particles[i].pos.y;\n    particlePositions[i*3+2] = particles[i].pos.z;\n  }\n  particleGeo.attributes.position.needsUpdate = true;\n  particleSystem.geometry.setDrawRange(0, count);\n  particleMat.opacity = count > 0 ? 1.0 : 0;\n}\n\nconst raycaster = new THREE.Raycaster();\nconst gamePlane  = new THREE.Plane(new THREE.Vector3(0, 1, 0), 0);\nconst mouseNDC   = new THREE.Vector2(-999, -999);\nconst mouseWorld = new THREE.Vector3();\nfunction updateMouseWorld() {\n  raycaster.setFromCamera(mouseNDC, camera);\n  raycaster.ray.intersectPlane(gamePlane, mouseWorld);\n}\n\nlet state   = 'levelselect';\nlet score   = 0;\nlet hiScore = (CACHE.get('hi', { easy: 0, medium: 0, hard: 0 }))[currentDifficulty] || 0;\nlet currentSpeed = CONFIG.initialSpeed;\nlet wallsEnabled = CONFIG.wallsEnabled;\nlet growthPending = 0;\nlet frameCount = 0, lastFpsTime = 0, fps = 60;\nlet lowFpsStreak = 0;\n\nlet sessionStart    = 0;\nlet sessionFood     = 0;\nlet sessionMaxLen   = 0;\nlet milestoneDone   = new Set();\n\nconst headPos  = new THREE.Vector3(0, 0.45, 0);\nlet   headDir  = new THREE.Vector3(0, 0, -1);\nconst segments = [];\nconst foodPos = new THREE.Vector3();\n\nconst keys = {};\nlet usingKeyboard = false;\nlet keyDir = new THREE.Vector3();\nconst speedPips = document.querySelectorAll('.speed-pip');\n\nconst _mouseFlat = new THREE.Vector3();\nconst _toMouse   = new THREE.Vector3();\nconst _segDiff   = new THREE.Vector3();\nconst _headPrev  = new THREE.Vector3();\nconst _sweepAB   = new THREE.Vector3();\nconst _sweepAP   = new THREE.Vector3();\nconst _sweepHit  = new THREE.Vector3();\n\nfunction pointToSegmentDistanceSq(point, segA, segB) {\n  _sweepAB.copy(segB).sub(segA);\n  const abLenSq = _sweepAB.lengthSq();\n  if (abLenSq < 1e-8) return point.distanceToSquared(segA);\n  _sweepAP.copy(point).sub(segA);\n  let t = _sweepAP.dot(_sweepAB) / abLenSq;\n  t = Math.max(0, Math.min(1, t));\n  _sweepHit.copy(segA).addScaledVector(_sweepAB, t);\n  return point.distanceToSquared(_sweepHit);\n}\n\nlet cachedSpacing   = parseFloat(document.getElementById('spacing-slider').value);\nlet cachedSmoothing = parseFloat(document.getElementById('smooth-slider').value);\ndocument.getElementById('spacing-slider').addEventListener('input', e => { cachedSpacing   = parseFloat(e.target.value); });\ndocument.getElementById('smooth-slider').addEventListener('input',  e => { cachedSmoothing = parseFloat(e.target.value); });\n\nfunction showToast(msg) {\n  const el = document.createElement('div');\n  el.className   = 'toast';\n  el.textContent = msg;\n  document.getElementById('toast-container').appendChild(el);\n  setTimeout(() => el.remove(), 2300);\n}\n\nfunction showScorePopup(amount, wx, wz) {\n  const popup = document.getElementById('score-popup');\n  const v = new THREE.Vector3(wx, 0.5, wz);\n  v.project(camera);\n  popup.textContent  = '+' + amount;\n  popup.style.left   = ((v.x * 0.5 + 0.5) * window.innerWidth)  + 'px';\n  popup.style.top    = ((-v.y * 0.5 + 0.5) * window.innerHeight) + 'px';\n  popup.style.opacity   = '1';\n  popup.style.transform = 'translate(-50%,-50%)';\n  let start = null;\n  function tick(ts) {\n    if (!start) start = ts;\n    const p = Math.min((ts - start) / 750, 1);\n    popup.style.opacity   = String(1 - p);\n    popup.style.transform = `translate(-50%, calc(-50% - ${p * 40}px)) scale(${1 + p * 0.25})`;\n    if (p < 1) requestAnimationFrame(tick);\n  }\n  requestAnimationFrame(tick);\n}\n\nfunction applyDifficulty(diff) {\n  const p = DIFF[diff];\n  CONFIG.initialSpeed           = p.initialSpeed;\n  CONFIG.wallsEnabled           = p.wallsEnabled;\n  CONFIG.scorePerFood           = p.scorePerFood;\n  CONFIG.speedIncreasePerFood   = p.speedIncreasePerFood;\n  CONFIG.selfCollisionFrom      = p.selfCollisionFrom;\n  CONFIG.boardSize              = p.boardSize;\n  CONFIG.growthPerFood          = p.growthPerFood;\n  wallsEnabled = p.wallsEnabled;\n  buildGrid();\n  buildWalls();\n  const badge = document.getElementById('level-badge');\n  badge.textContent     = p.label;\n  badge.style.color     = p.color;\n  badge.style.borderColor = p.color;\n  const wt = p.wallsEnabled ? 'PAREDES' : 'ENVOLVER';\n  document.getElementById('wall-badge').textContent     = wt;\n  document.getElementById('wall-mode-info').textContent = wt;\n  document.getElementById('start-diff-label').textContent = p.descLine;\n  hiScore = (CACHE.get('hi', { easy: 0, medium: 0, hard: 0 }))[diff] || 0;\n  document.getElementById('hi-val').textContent   = hiScore;\n  document.getElementById('final-hi').textContent = hiScore;\n  document.getElementById('speed-slider').value = String(p.initialSpeed);\n  cachedSpacing   = parseFloat(document.getElementById('spacing-slider').value);\n  cachedSmoothing = parseFloat(document.getElementById('smooth-slider').value);\n  CACHE.set('last_diff', diff);\n}\n\nfunction initGame() {\n  score         = 0;\n  currentSpeed  = CONFIG.initialSpeed;\n  growthPending = 0;\n  particles.length = 0;\n  sessionStart  = Date.now();\n  sessionFood   = 0;\n  sessionMaxLen = 0;\n  milestoneDone.clear();\n  headPos.set(0, 0.45, 0);\n  headDir.set(0, 0, -1);\n  segments.length = 0;\n  for (let i = 1; i <= 4; i++) segments.push(new THREE.Vector3(0, 0.36, i * CONFIG.segmentSpacing));\n  \n  // 💡 MODIFICADO: Reseteo de color de muerte a Neón cian vibrante\n  headMat.color.setHex(0x00ffe7);\n  headMat.emissive.setHex(0x00ffe7);\n  headMat.emissiveIntensity = 6.0;\n  headLight.color.setHex(0x00ffe7);\n  spawnFood();\n  updateUI();\n}\n\nfunction spawnFood() {\n  const B = CONFIG.boardSize - 2;\n  let tries = 0;\n  do {\n    foodPos.set((Math.random()*2-1)*B, 0.5, (Math.random()*2-1)*B);\n    tries++;\n  } while (isTooCloseToSnake(foodPos) && tries < 50);\n  foodMesh.position.copy(foodPos);\n  foodLight.position.copy(foodPos).y += 1;\n}\n\nfunction isTooCloseToSnake(pos) {\n  if (pos.distanceTo(headPos) < 2.5) return true;\n  for (const s of segments) if (pos.distanceTo(s) < 2.5) return true;\n  return false;\n}\n\nlet lastTime = performance.now();\n\nlet camTarget  = new THREE.Vector3();\nlet   camCurrent = new THREE.Vector3(0, CONFIG.camHeight, CONFIG.camDistance);\nconst camLookAt  = new THREE.Vector3();\n\nlet flashTimer = null;\nfunction flashScore() {\n  const el = document.getElementById('score-val');\n  el.classList.add('flash');\n  if (flashTimer) clearTimeout(flashTimer);\n  flashTimer = setTimeout(() => el.classList.remove('flash'), 320);\n}\n\nfunction checkMilestones() {\n  for (const m of MILESTONES) {\n    if (score >= m.score && !milestoneDone.has(m.score)) {\n      milestoneDone.add(m.score);\n      showToast(m.msg);\n    }\n  }\n}\n\nfunction update(dt) {\n  if (state !== 'play') return;\n\n  _headPrev.copy(headPos);\n  updateMouseWorld();\n  const spacing   = cachedSpacing;\n  const smoothing = cachedSmoothing;\n\n  if (usingKeyboard) {\n    if (keyDir.lengthSq() > 0) { headDir.lerp(keyDir, 0.3); headDir.normalize(); }\n    headPos.addScaledVector(headDir, currentSpeed * dt);\n  } else {\n    _mouseFlat.set(mouseWorld.x, headPos.y, mouseWorld.z);\n    _toMouse.copy(_mouseFlat).sub(headPos);\n    const d = _toMouse.length();\n    if (d > 0.05) { _toMouse.normalize(); headDir.lerp(_toMouse, Math.min(1, smoothing / 20)); headDir.normalize(); }\n    headPos.addScaledVector(headDir, Math.min(currentSpeed * dt, d));\n  }\n\n  const B = CONFIG.boardSize;\n  if (wallsEnabled) {\n    const wallLimit = B - CONFIG.headRadius;\n    if (Math.abs(headPos.x) > wallLimit || Math.abs(headPos.z) > wallLimit) { triggerDeath('wall'); return; }\n  } else {\n    if (headPos.x >  B) headPos.x = -B;\n    if (headPos.x < -B) headPos.x =  B;\n    if (headPos.z >  B) headPos.z = -B;\n    if (headPos.z < -B) headPos.z =  B;\n  }\n\n  if (growthPending > 0 && Math.random() < 0.5) {\n    const tail   = segments.length > 0 ? segments[segments.length - 1] : headPos;\n    const before = segments.length > 1 ? segments[segments.length - 2] : headPos;\n    const dir    = tail.clone().sub(before);\n    if (dir.lengthSq() < 0.0001) dir.copy(headDir).negate();\n    dir.normalize();\n    segments.push(tail.clone().add(dir.multiplyScalar(spacing)));\n    growthPending--;\n  }\n\n  const checkFrom = Math.min(CONFIG.selfCollisionFrom, segments.length);\n  const collisionRadius = CONFIG.headRadius + CONFIG.segRadius - 0.05;\n  const collisionRadiusSq = collisionRadius * collisionRadius;\n  for (let i = checkFrom; i < segments.length; i++) {\n    const hitNow   = headPos.distanceToSquared(segments[i]) < collisionRadiusSq;\n    const hitSweep = pointToSegmentDistanceSq(segments[i], _headPrev, headPos) < collisionRadiusSq;\n    if (hitNow || hitSweep) {\n      if (CONFIG.debugVisible) document.getElementById('dbg-coll').textContent = 'seg ' + i;\n      triggerDeath('self'); return;\n    }\n  }\n\n  for (let i = 0; i < segments.length; i++) {\n    const prev = i === 0 ? headPos : segments[i - 1];\n    const curr = segments[i];\n    _segDiff.copy(curr).sub(prev);\n    const dist = _segDiff.length();\n    if (dist > spacing) { _segDiff.normalize().multiplyScalar(dist - spacing); curr.sub(_segDiff); }\n    curr.y = 0.36;\n  }\n\n  const curLen = segments.length + 1;\n  if (curLen > sessionMaxLen) sessionMaxLen = curLen;\n\n  if (headPos.distanceTo(foodPos) < CONFIG.headRadius + CONFIG.foodRadius + 0.1) {\n    score        += CONFIG.scorePerFood;\n    currentSpeed += CONFIG.speedIncreasePerFood;\n    growthPending += CONFIG.growthPerFood;\n    sessionFood++;\n    showScorePopup(CONFIG.scorePerFood, foodPos.x, foodPos.z);\n    spawnParticles(foodPos.clone());\n    spawnFood();\n    flashScore();\n    checkMilestones();\n  }\n\n  headPos.y = 0.45;\n  headMesh.position.copy(headPos);\n  headLight.position.copy(headPos).y += 0.8;\n  if (headDir.lengthSq() > 0.01) headMesh.rotation.y = Math.atan2(headDir.x, headDir.z);\n\n  updateBodyInstances(segments);\n\n  foodMesh.rotation.y += dt * 1.5;\n  foodMesh.position.y  = 0.5 + Math.sin(Date.now() * 0.003) * 0.15;\n  foodLight.position.y = foodMesh.position.y + 0.6;\n\n  updateParticles(dt);\n\n  if (CONFIG.debugVisible) {\n    document.getElementById('dbg-head').textContent    = headPos.x.toFixed(1) + ', ' + headPos.z.toFixed(1);\n    document.getElementById('dbg-segs').textContent    = segments.length;\n    document.getElementById('dbg-food').textContent    = foodPos.x.toFixed(1) + ', ' + foodPos.z.toFixed(1);\n    document.getElementById('dbg-spacing').textContent = spacing.toFixed(1);\n  }\n\n  const zf = Math.min(1, segments.length / 50);\n  camTarget.set(headPos.x * 0.3, CONFIG.camHeight + zf * 15, headPos.z * 0.3 + CONFIG.camDistance + zf * 6);\n  camCurrent.lerp(camTarget, CONFIG.camFollowStrength);\n  camera.position.copy(camCurrent);\n  camLookAt.set(headPos.x * 0.2, 0, headPos.z * 0.2);\n  camera.lookAt(camLookAt);\n\n  updateUI();\n}\n\nfunction triggerDeath(cause) {\n  if (state === 'dead') return;\n  state = 'dead';\n  const elapsed = Math.floor((performance.now() - sessionStart) / 1000);\n  const { isNew, hiScores } = CACHE.saveRun(currentDifficulty, score, { time: elapsed, food: sessionFood, len: sessionMaxLen });\n  hiScore = hiScores[currentDifficulty] || 0;\n  document.getElementById('final-score').textContent = score;\n  document.getElementById('final-hi').textContent    = hiScore;\n  document.getElementById('hi-val').textContent      = hiScore;\n  document.getElementById('new-record-badge').classList.toggle('hidden', !isNew);\n  if (isNew) refreshDiffCards();\n  const mm = String(Math.floor(elapsed / 60));\n  const ss = String(elapsed % 60).padStart(2, '0');\n  document.getElementById('stat-time').textContent = mm + ':' + ss;\n  document.getElementById('stat-food').textContent = sessionFood;\n  document.getElementById('stat-len').textContent  = sessionMaxLen;\n  const hist  = CACHE.get('history', { easy: [], medium: [], hard: [] });\n  const runs  = hist[currentDifficulty] || [];\n  const tbody = document.querySelector('#history-table tbody');\n  tbody.innerHTML = '';\n  runs.forEach((r, idx) => {\n    const tr = document.createElement('tr');\n    tr.innerHTML = '<td>#' + (idx+1) + '</td><td>' + r.score + '</td><td>' + r.food + ' comida · len ' + r.len + '</td>';\n    tbody.appendChild(tr);\n  });\n  document.getElementById('game-over-screen').classList.remove('hidden');\n  \n  // 💡 MODIFICADO: Cabeza carmesí de muerte hiper-radioactiva al chocar\n  headMat.color.setHex(0xff3366);\n  headMat.emissive.setHex(0xff3366);\n  headMat.emissiveIntensity = 6.0;\n  headLight.color.setHex(0xff3366);\n}\n\nfunction updateUI() {\n  document.getElementById('score-val').textContent = score;\n  document.getElementById('hi-val').textContent    = hiScore;\n  document.getElementById('len-val').textContent   = segments.length + 1;\n  document.getElementById('spd-val').textContent   = currentSpeed.toFixed(1);\n  const active = Math.round((currentSpeed / 30) * speedPips.length);\n  speedPips.forEach((p, i) => p.classList.toggle('active', i < active));\n}\n\nfunction updateFPS(now) {\n  frameCount++;\n  if (now - lastFpsTime >= 1000) {\n    fps = frameCount; frameCount = 0; lastFpsTime = now;\n    if (CONFIG.debugVisible) document.getElementById('dbg-fps').textContent = fps;\n    lowFpsStreak = fps < 30 ? lowFpsStreak + 1 : 0;\n    if (lowFpsStreak >= 2 && CONFIG.quality !== 'low') {\n      CONFIG.quality = 'low';\n      renderer.setPixelRatio(1);\n      renderer.shadowMap.enabled = false;\n      CONFIG.particleCount = 10;\n      document.getElementById('quality-select').value = 'low';\n    }\n  }\n}\n\nconst cursorEl = document.getElementById('cursor');\nwindow.addEventListener('mousemove', e => {\n  usingKeyboard = false;\n  cursorEl.style.left = e.clientX + 'px';\n  cursorEl.style.top  = e.clientY + 'px';\n  mouseNDC.x =  (e.clientX / window.innerWidth)  * 2 - 1;\n  mouseNDC.y = -(e.clientY / window.innerHeight) * 2 + 1;\n});\nwindow.addEventListener('touchmove', e => {\n  if (controlMode === 'swipe') {\n    e.preventDefault();\n    usingKeyboard = false;\n    const t = e.touches[0];\n    mouseNDC.x =  (t.clientX / window.innerWidth)  * 2 - 1;\n    mouseNDC.y = -(t.clientY / window.innerHeight) * 2 + 1;\n  }\n}, { passive: false });\n\nwindow.addEventListener('keydown', e => {\n  keys[e.code] = true;\n  switch (e.code) {\n    case 'Space':\n      e.preventDefault();\n      if (state === 'play') {\n        state = 'paused'; document.getElementById('pause-badge').classList.remove('hidden');\n      } else if (state === 'paused') {\n        state = 'play';   document.getElementById('pause-badge').classList.add('hidden');\n      }\n      break;\n    case 'KeyR':\n      if (state === 'play' || state === 'paused' || state === 'dead') restartGame();\n      break;\n    case 'KeyT': {\n      wallsEnabled = !wallsEnabled;\n      CONFIG.wallsEnabled = wallsEnabled;\n      buildWalls();\n      const wt = wallsEnabled ? 'PAREDES' : 'ENVOLVER';\n      document.getElementById('wall-badge').textContent     = wt;\n      document.getElementById('wall-mode-info').textContent = wt;\n      break;\n    }\n    case 'KeyM':\n      if (!e.repeat) cycleControlMode();\n      break;\n    case 'Escape':\n      document.getElementById('settings-panel').classList.toggle('hidden');\n      break;\n    case 'Backquote':\n      CONFIG.debugVisible = !CONFIG.debugVisible;\n      document.getElementById('debug-overlay').classList.toggle('hidden', !CONFIG.debugVisible);\n      break;\n    case 'Equal': case 'NumpadAdd':      currentSpeed = Math.min(30, currentSpeed + 1); break;\n    case 'Minus': case 'NumpadSubtract': currentSpeed = Math.max(3,  currentSpeed - 1); break;\n  }\n  if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','KeyW','KeyA','KeyS','KeyD'].includes(e.code)) usingKeyboard = true;\n});\nwindow.addEventListener('keyup', e => { keys[e.code] = false; });\n\nfunction updateKeyDir() {\n  keyDir.set(0, 0, 0);\n  if (keys['ArrowUp']    || keys['KeyW']) keyDir.z -= 1;\n  if (keys['ArrowDown']  || keys['KeyS']) keyDir.z += 1;\n  if (keys['ArrowLeft']  || keys['KeyA']) keyDir.x -= 1;\n  if (keys['ArrowRight'] || keys['KeyD']) keyDir.x += 1;\n  if (keyDir.lengthSq() > 0) keyDir.normalize();\n}\n\nconst isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);\nlet controlMode = CACHE.get('ctrl_mode', isTouchDevice ? 'joystick' : 'mouse');\n\nfunction applyControlMode(mode) {\n  controlMode = mode;\n  CACHE.set('ctrl_mode', mode);\n  const joystickZone = document.getElementById('joystick-zone');\n  const toggleBtn    = document.getElementById('ctrl-toggle');\n  const iconEl       = document.getElementById('ctrl-icon');\n  const labelEl      = document.getElementById('ctrl-label');\n  toggleBtn.classList.remove('active-joystick', 'active-swipe');\n  document.body.classList.remove('touch-mode');\n  joystickZone.classList.remove('visible');\n  if (mode === 'joystick') {\n    joystickZone.classList.add('visible');\n    toggleBtn.classList.add('active-joystick');\n    document.body.classList.add('touch-mode');\n    iconEl.textContent  = '🕹';\n    labelEl.textContent = 'JOYSTICK';\n  } else if (mode === 'swipe') {\n    toggleBtn.classList.add('active-swipe');\n    document.body.classList.add('touch-mode');\n    iconEl.textContent  = '👆';\n    labelEl.textContent = 'DESLIZAR';\n  } else {\n    iconEl.textContent  = '🖱';\n    labelEl.textContent = 'RATÓN';\n  }\n}\n\ndocument.getElementById('ctrl-toggle').addEventListener('click', cycleControlMode);\n\nfunction cycleControlMode() {\n  const next = { mouse: 'joystick', joystick: 'swipe', swipe: 'mouse' };\n  applyControlMode(next[controlMode] || 'mouse');\n  showToast(\n    controlMode === 'joystick' ? '🕹  JOYSTICK' :\n    controlMode === 'swipe'    ? '👆  DESLIZAR'  :\n                                 '🖱  RATÓN'\n  );\n}\n\napplyControlMode(controlMode);\n\n(function() {\n  const zone = document.getElementById('joystick-zone');\n  const knob = document.getElementById('joystick-knob');\n  const RAD  = 65;\n  let active = false, cx = 0, cy = 0;\n  zone.addEventListener('touchstart', e => {\n    if (controlMode !== 'joystick') return;\n    e.stopPropagation();\n    active = true;\n    const r = zone.getBoundingClientRect();\n    cx = r.left + r.width / 2;\n    cy = r.top  + r.height / 2;\n    usingKeyboard = true;\n  }, { passive: true });\n  window.addEventListener('touchmove', e => {\n    if (!active || controlMode !== 'joystick') return;\n    const t  = e.touches[0];\n    const dx = t.clientX - cx, dy = t.clientY - cy;\n    const len = Math.sqrt(dx * dx + dy * dy);\n    const cl  = Math.min(len, RAD);\n    const nx  = len > 0 ? dx / len : 0;\n    const ny  = len > 0 ? dy / len : 0;\n    knob.style.transform = 'translate(calc(-50% + ' + (nx * cl) + 'px), calc(-50% + ' + (ny * cl) + 'px))';\n    if (len > 10) {\n      usingKeyboard = true;\n      keyDir.set(nx, 0, ny);\n      if (keyDir.lengthSq() > 0) keyDir.normalize();\n    }\n  }, { passive: true });\n  window.addEventListener('touchend', e => {\n    if (!active) return;\n    active = false;\n    knob.style.transform = 'translate(-50%,-50%)';\n    keyDir.set(0, 0, 0);\n    const anyKey = Object.values(keys).some(Boolean);\n    if (!anyKey) usingKeyboard = false;\n  }, { passive: true });\n})();\n\nwindow.addEventListener('touchstart', e => {\n  if (controlMode !== 'swipe') return;\n  usingKeyboard = false;\n  const t = e.touches[0];\n  mouseNDC.x =  (t.clientX / window.innerWidth)  * 2 - 1;\n  mouseNDC.y = -(t.clientY / window.innerHeight) * 2 + 1;\n}, { passive: true });\n\nlet resizeDebounceTimer = null;\nwindow.addEventListener('resize', () => {\n  clearTimeout(resizeDebounceTimer);\n  resizeDebounceTimer = setTimeout(() => {\n    camera.aspect = window.innerWidth / window.innerHeight;\n    camera.updateProjectionMatrix();\n    renderer.setSize(window.innerWidth, window.innerHeight);\n  }, 100);\n});\n\ndocument.querySelectorAll('.diff-card').forEach(card => {\n  const select = () => {\n    currentDifficulty = card.dataset.diff;\n    document.querySelectorAll('.diff-card').forEach(c => c.classList.remove('selected'));\n    card.classList.add('selected');\n  };\n  card.addEventListener('click', select);\n  card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); select(); } });\n});\n\ndocument.getElementById('diff-play-btn').addEventListener('click', () => {\n  applyDifficulty(currentDifficulty);\n  document.getElementById('level-select-screen').classList.add('hidden');\n  document.getElementById('start-screen').classList.remove('hidden');\n  state = 'start';\n});\n\ndocument.getElementById('start-btn').addEventListener('click', () => {\n  if (state !== 'start') return;\n  state = 'play';\n  document.getElementById('start-screen').classList.add('hidden');\n  initGame();\n  lastTime = performance.now();\n});\n\nfunction restartGame() {\n  if (state !== 'play' && state !== 'paused' && state !== 'dead') return;\n  state = 'play';\n  document.getElementById('game-over-screen').classList.add('hidden');\n  document.getElementById('pause-badge').classList.add('hidden');\n  initGame();\n  lastTime = performance.now();\n  particles.length = 0;\n}\ndocument.getElementById('restart-btn').addEventListener('click', restartGame);\n\ndocument.getElementById('menu-btn').addEventListener('click', () => {\n  document.getElementById('game-over-screen').classList.add('hidden');\n  refreshDiffCards();\n  document.getElementById('level-select-screen').classList.remove('hidden');\n  state = 'levelselect';\n});\n\ndocument.getElementById('quality-select').addEventListener('change', e => {\n  CONFIG.quality = e.target.value;\n  CACHE.set('settings', { quality: CONFIG.quality });\n  switch (CONFIG.quality) {\n    case 'low':  renderer.setPixelRatio(1);                                      renderer.shadowMap.enabled = false; CONFIG.particleCount = 10; break;\n    case 'med':  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5)); renderer.shadowMap.enabled = true;  CONFIG.particleCount = 30; break;\n    case 'high': renderer.setPixelRatio(window.devicePixelRatio);               renderer.shadowMap.enabled = true;  CONFIG.particleCount = 60; break;\n  }\n  document.getElementById('particle-count').value = CONFIG.particleCount;\n});\ndocument.getElementById('particle-count').addEventListener('input', e => { CONFIG.particleCount = parseInt(e.target.value); });\ndocument.getElementById('speed-slider').addEventListener('input',   e => { currentSpeed = parseFloat(e.target.value); });\n\n(function() {\n  const p = DIFF[currentDifficulty];\n  const badge = document.getElementById('level-badge');\n  badge.textContent       = p.label;\n  badge.style.color       = p.color;\n  badge.style.borderColor = p.color;\n  document.getElementById('hi-val').textContent   = hiScore;\n  document.getElementById('final-hi').textContent = hiScore;\n})();\n\ndocument.getElementById('loading-screen').style.display = 'none';\n\nfunction animate(now) {\n  requestAnimationFrame(animate);\n  const dt = Math.min((now - lastTime) / 1000, 0.033);\n  lastTime = now;\n  updateFPS(now);\n  updateKeyDir();\n  update(dt);\n  renderer.render(scene, camera);\n}\nrequestAnimationFrame(animate);\n\n} // fin initSerpentine"
        }
      }
    }
  }
}