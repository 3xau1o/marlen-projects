      "c": {
        "index.ts": {
          "k": 1,
          "c": "// ─── Estado global ───────────────────────────────────────────────────────────\nvar anguloMundo = 0;\nvar velocidadMundo = 0;\nvar moverTunel = 0;\nvar puntos = 0;\nvar nivel = 1;\nvar estado = \"jugar\";\nvar flashDisparo = 0;\n\nvar ultimoDisparo = 0;\nvar ESPERA_DISPARO = 350;\n\nvar cubos = [];\nvar gemas = [];\nvar asteroides = [];\nvar modeloAsteroide;\n\n// Variables para nuestra nueva interfaz HTML (DOM)\nvar uiNivel, uiPuntos, uiControles, uiChoque;\n\n// ─── Constantes del túnel ─────────────────────────────────────────────────────\nvar CARRILES = 14;\nvar ANGULO_JUGADOR = Math.PI / 2;\nvar RADIO_TUNEL = 150;\nvar Z_JUGADOR = 130;\nvar Z_LEJOS = -1350;\n\nvar angulosCarril = [];\nvar carrilX = [];\nvar carrilY = [];\nvar JUGADOR_X = 0;\nvar JUGADOR_Y = 0;\n\n// ─── Ciclo de vida p5 ─────────────────────────────────────────────────────────\nfunction preload() {\n  modeloAsteroide = loadModel(\"Asteroid.obj\");\n}\n\nfunction setup() {\n  // 1. Creamos un contenedor principal para agrupar el juego y la UI\n  var contenedor = createDiv();\n  contenedor.style('position', 'relative');\n  contenedor.style('width', '600px');\n  contenedor.style('height', '600px');\n\n  // 2. Creamos el lienzo WEBGL y lo metemos en el contenedor\n  var lienzo = createCanvas(600, 600, WEBGL);\n  lienzo.parent(contenedor);\n  angleMode(RADIANS);\n\n  // 3. Inicializamos la nueva interfaz HTML\n  crearInterfazHTML(contenedor);\n\n  construirCacheCarriles();\n  reiniciarJuego();\n}\n\nfunction draw() {\n  background(8, 10, 18);\n  perspective(PI / 3, width / height, 8, 2600);\n  camera(0, 0, 430, 0, 0, -360, 0, 1, 0);\n\n  ambientLight(45, 50, 70);\n  pointLight(80, 150, 255, -170, -160, 260);\n  pointLight(255, 90, 115, 180, 130, 160);\n\n  if (estado === \"jugar\") actualizarJuego();\n\n  dibujarTunel();\n  dibujarGemas();\n  dibujarCubos();\n  dibujarAsteroides();\n  dibujarDisparo();\n  dibujarBola();\n  \n  // Actualizamos los textos HTML\n  actualizarHud();\n}\n\n// ─── NUEVA ESTRATEGIA: Interfaz HTML (DOM) ────────────────────────────────────\nfunction crearInterfazHTML(padre) {\n  // Nivel - Esquina Superior Izquierda\n  uiNivel = createDiv('Nivel: 1');\n  uiNivel.parent(padre);\n  uiNivel.style('position', 'absolute');\n  uiNivel.style('top', '10px');\n  uiNivel.style('left', '15px');\n  uiNivel.style('color', '#BED2E1');\n  uiNivel.style('font-size', '20px'); // Tamaño reducido\n  uiNivel.style('font-family', 'Arial, sans-serif');\n  uiNivel.style('font-weight', 'bold');\n  uiNivel.style('pointer-events', 'none'); // Para que los clicks pasen al juego\n\n  // Puntos - Esquina Superior Derecha\n  uiPuntos = createDiv('Puntos: 0');\n  uiPuntos.parent(padre);\n  uiPuntos.style('position', 'absolute');\n  uiPuntos.style('top', '10px');\n  uiPuntos.style('right', '15px');\n  uiPuntos.style('color', '#FFFFFF');\n  uiPuntos.style('font-size', '24px'); // Tamaño reducido\n  uiPuntos.style('font-family', 'Arial, sans-serif');\n  uiPuntos.style('font-weight', 'bold');\n  uiPuntos.style('pointer-events', 'none');\n\n  // Controles - Esquina Inferior Izquierda (Texto en una fila)\n  uiControles = createDiv('Controles: A-D / Flechas (Moverse) &nbsp;&nbsp;|&nbsp;&nbsp; Click / Espacio (Disparar)');\n  uiControles.parent(padre);\n  uiControles.style('position', 'absolute');\n  uiControles.style('bottom', '12px');\n  uiControles.style('left', '15px');\n  uiControles.style('color', '#AABCCD');\n  uiControles.style('font-size', '16px'); // Tamaño reducido\n  uiControles.style('font-family', 'Arial, sans-serif');\n  uiControles.style('pointer-events', 'none');\n\n  // Pantalla de Choque - Centrada (Textos reducidos proporcionalmente)\n  uiChoque = createDiv('<div style=\"font-size:48px; color:#FF5A69; font-weight:bold; margin-bottom:10px;\">CHOQUE</div><div style=\"font-size:20px; color:#FFF;\">Presiona R para reiniciar</div>');\n  uiChoque.parent(padre);\n  uiChoque.style('position', 'absolute');\n  uiChoque.style('top', '50%');\n  uiChoque.style('left', '50%');\n  uiChoque.style('transform', 'translate(-50%, -50%)');\n  uiChoque.style('background', 'rgba(0, 0, 0, 0.85)');\n  uiChoque.style('padding', '35px 60px');\n  uiChoque.style('border-radius', '12px');\n  uiChoque.style('text-align', 'center');\n  uiChoque.style('font-family', 'Arial, sans-serif');\n  uiChoque.style('display', 'none'); // Oculto por defecto\n}\n\nfunction actualizarHud() {\n  // Simplemente reescribimos el texto HTML interno\n  uiNivel.html(\"Nivel: \" + nivel);\n  uiPuntos.html(\"Puntos: \" + floor(puntos));\n\n  // Mostramos u ocultamos el cartel central de choque con CSS\n  if (estado === \"choque\") {\n    uiChoque.style('display', 'block');\n  } else {\n    uiChoque.style('display', 'none');\n  }\n}\n\n// ─── Inicialización y Reciclaje ───────────────────────────────────────────────\nfunction construirCacheCarriles() {\n  angulosCarril = [];\n  carrilX = [];\n  carrilY = [];\n\n  for (var i = 0; i < CARRILES; i++) {\n    var a = i * TWO_PI / CARRILES;\n    angulosCarril[i] = a;\n    carrilX[i] = cos(a) * RADIO_TUNEL;\n    carrilY[i] = sin(a) * RADIO_TUNEL;\n  }\n\n  JUGADOR_X = cos(ANGULO_JUGADOR) * RADIO_TUNEL;\n  JUGADOR_Y = sin(ANGULO_JUGADOR) * RADIO_TUNEL;\n}\n\nfunction reiniciarJuego() {\n  anguloMundo = 0;\n  velocidadMundo = 0;\n  moverTunel = 0;\n  puntos = 0;\n  nivel = 1;\n  estado = \"jugar\";\n  flashDisparo = 0;\n  ultimoDisparo = 0;\n  cubos = [];\n  gemas = [];\n  asteroides = [];\n\n  for (var i = 0; i < 18; i++) cubos.push(crearCubo(-150 - i * 68));\n  for (var j = 0; j < 10; j++) gemas.push(crearGema(-120 - j * 96));\n  for (var k = 0; k < 3; k++) asteroides.push(crearAsteroide(-200 - k * 180));\n}\n\nfunction crearCubo(z) { return { z: z, carril: floor(random(CARRILES)), tamanio: random(30, 44) }; }\nfunction crearGema(z) { return { z: z, carril: floor(random(CARRILES)), activa: true, giro: random(TWO_PI) }; }\nfunction crearAsteroide(z) {\n  return { z: z, carril: floor(random(CARRILES)), golpes: 0, maxGolpes: 3, tamanio: random(18, 28), giro: random(TWO_PI), velGiro: random(0.008, 0.025) };\n}\n\nfunction anguloDeCarril(carril) {\n  return angulosCarril[carril] + anguloMundo;\n}\n\nfunction reciclar(obj, tipo) {\n  obj.z = random(Z_LEJOS, -760);\n  obj.carril = floor(random(CARRILES));\n  if (tipo === \"cubo\") obj.tamanio = random(30, 44);\n  else if (tipo === \"gema\") { obj.activa = true; obj.giro = random(TWO_PI); }\n  else if (tipo === \"asteroide\") { obj.golpes = 0; obj.tamanio = random(18, 28); obj.giro = random(TWO_PI); obj.velGiro = random(0.008, 0.025); }\n}\n\n// ─── Actualización del juego ──────────────────────────────────────────────────\nfunction actualizarJuego() {\n  var entrada = 0;\n  if (keyIsDown(LEFT_ARROW) || keyIsDown(65)) entrada = -1;\n  if (keyIsDown(RIGHT_ARROW) || keyIsDown(68)) entrada = 1;\n\n  velocidadMundo += entrada * 0.018;\n  velocidadMundo *= 0.88;\n  velocidadMundo = constrain(velocidadMundo, -0.09, 0.09);\n  anguloMundo += velocidadMundo;\n\n  nivel = floor(puntos / 120) + 1;\n  var velMovimiento = 2.2 + nivel * 0.42;\n  moverTunel += velMovimiento;\n\n  actualizarCubos(velMovimiento);\n  actualizarGemas(velMovimiento);\n  actualizarAsteroides(velMovimiento);\n  ajustarDificultad();\n\n  if (flashDisparo > 0) flashDisparo *= 0.82;\n}\n\nfunction actualizarCubos(vel) {\n  for (var i = 0; i < cubos.length; i++) {\n    var c = cubos[i];\n    c.z += vel;\n    if (c.z > 210) { reciclar(c, \"cubo\"); continue; }\n    if (abs(c.z - Z_JUGADOR) < 18 && difAngulo(anguloDeCarril(c.carril), ANGULO_JUGADOR) < 0.26) estado = \"choque\";\n  }\n}\n\nfunction actualizarGemas(vel) {\n  for (var i = 0; i < gemas.length; i++) {\n    var g = gemas[i];\n    g.z += vel;\n    if (g.z > 210) { reciclar(g, \"gema\"); continue; }\n    if (g.activa && abs(g.z - Z_JUGADOR) < 20 && difAngulo(anguloDeCarril(g.carril), ANGULO_JUGADOR) < 0.24) {\n      g.activa = false;\n      puntos += 20;\n    }\n  }\n}\n\nfunction actualizarAsteroides(vel) {\n  for (var i = 0; i < asteroides.length; i++) {\n    var ast = asteroides[i];\n    ast.z += vel;\n    ast.giro += ast.velGiro;\n    if (ast.z > 210) { reciclar(ast, \"asteroide\"); continue; }\n    if (abs(ast.z - Z_JUGADOR) < 22 && difAngulo(anguloDeCarril(ast.carril), ANGULO_JUGADOR) < 0.28) estado = \"choque\";\n  }\n}\n\nfunction ajustarDificultad() {\n  var metaCubos = min(18 + nivel * 2, 34);\n  var metaGemas = min(10 + floor(nivel / 2), 16);\n  var metaAsteroides = min(3 + floor(nivel / 4), 10);\n\n  while (cubos.length < metaCubos) cubos.push(crearCubo(random(Z_LEJOS, -760)));\n  while (gemas.length < metaGemas) gemas.push(crearGema(random(Z_LEJOS, -700)));\n  while (asteroides.length < metaAsteroides) asteroides.push(crearAsteroide(random(Z_LEJOS, -760)));\n}\n\n// ─── Disparo ──────────────────────────────────────────────────────────────────\nfunction disparar() {\n  if (estado !== \"jugar\") return;\n  if (millis() - ultimoDisparo < ESPERA_DISPARO) return;\n  ultimoDisparo = millis();\n  flashDisparo = 1;\n\n  var objCercano = null;\n  var zMasCercano = -99999;\n  var candidatos = [{ lista: cubos, tipo: \"cubo\" }, { lista: asteroides, tipo: \"asteroide\" }];\n\n  for (var g = 0; g < candidatos.length; g++) {\n    var lista = candidatos[g].lista;\n    var tipo  = candidatos[g].tipo;\n    for (var i = 0; i < lista.length; i++) {\n      var obj = lista[i];\n      if (obj.z < Z_LEJOS || obj.z > Z_JUGADOR) continue;\n      if (difAngulo(anguloDeCarril(obj.carril), ANGULO_JUGADOR) >= 0.2) continue;\n      if (obj.z > zMasCercano) {\n        objCercano  = { tipo: tipo, ref: obj };\n        zMasCercano = obj.z;\n      }\n    }\n  }\n\n  if (!objCercano) return;\n\n  if (objCercano.tipo === \"asteroide\") {\n    objCercano.ref.golpes++;\n    if (objCercano.ref.golpes >= objCercano.ref.maxGolpes) {\n      puntos += 50;\n      reciclar(objCercano.ref, \"asteroide\");\n    }\n  } else {\n    reciclar(objCercano.ref, \"cubo\");\n  }\n}\n\n// ─── Dibujo 3D ────────────────────────────────────────────────────────────────\nfunction dibujarTunel() {\n  push();\n  rotateZ(anguloMundo);\n  for (var i = 0; i < 28; i++) {\n    var z = ((i * 64 + moverTunel) % 1792) - 1520;\n    var alfa = map(z, Z_LEJOS, 180, 35, 190);\n    push();\n    translate(0, 0, z);\n    noFill();\n    stroke(118, 130, 154, alfa);\n    strokeWeight(map(z, Z_LEJOS, 180, 0.6, 2.1));\n    torus(RADIO_TUNEL, 1.6, 24, 5);\n    pop();\n  }\n  for (var carril = 0; carril < CARRILES; carril++) {\n    var x = carrilX[carril];\n    var y = carrilY[carril];\n    stroke(carril % 2 === 0 ? 125 : 75, 130, 155, carril % 2 === 0 ? 120 : 80);\n    strokeWeight(carril % 2 === 0 ? 1.6 : 0.9);\n    line(x, y, Z_LEJOS, x, y, 190);\n  }\n  pop();\n}\n\nfunction dibujarCubos() {\n  push();\n  rotateZ(anguloMundo);\n  for (var i = 0; i < cubos.length; i++) {\n    var c = cubos[i];\n    push();\n    translate(carrilX[c.carril], carrilY[c.carril], c.z);\n    rotateZ(angulosCarril[c.carril] + HALF_PI);\n    rotateX(frameCount * 0.015);\n    rotateY(frameCount * 0.01);\n    ambientMaterial(235, 55, 82);\n    specularMaterial(255, 90, 112);\n    shininess(35);\n    box(c.tamanio);\n    noFill();\n    stroke(255, 120, 135, 150);\n    strokeWeight(1.2);\n    box(c.tamanio * 1.18);\n    pop();\n  }\n  pop();\n}\n\nfunction dibujarAsteroides() {\n  push();\n  rotateZ(anguloMundo);\n  for (var i = 0; i < asteroides.length; i++) {\n    var ast = asteroides[i];\n    push();\n    translate(carrilX[ast.carril], carrilY[ast.carril], ast.z);\n    rotateZ(angulosCarril[ast.carril] + HALF_PI);\n    rotateY(ast.giro);\n    rotateX(sin(ast.giro * 0.7) * 0.3);\n\n    var danio = ast.golpes / ast.maxGolpes;\n    var r = floor(lerp(160, 255, danio));\n    var vg = floor(lerp(150, 80, danio));\n    var b  = floor(lerp(140, 50, danio));\n\n    ambientMaterial(r, vg, b);\n    specularMaterial(r + 20, vg + 10, b);\n    shininess(25);\n    var escala = ast.tamanio / 700;\n    scale(escala);\n    model(modeloAsteroide);\n\n    noFill();\n    stroke(r + 40, vg + 20, b, 100 + danio * 80);\n    strokeWeight(0.8 + danio * 1.2);\n    scale(1.08);\n    model(modeloAsteroide);\n    pop();\n  }\n  pop();\n}\n\nfunction dibujarGemas() {\n  push();\n  rotateZ(anguloMundo);\n  for (var i = 0; i < gemas.length; i++) {\n    var g = gemas[i];\n    if (!g.activa) continue;\n    push();\n    translate(carrilX[g.carril], carrilY[g.carril], g.z);\n    rotateZ(frameCount * 0.06 + g.giro);\n    rotateY(frameCount * 0.035);\n    ambientMaterial(255, 214, 65);\n    specularMaterial(255, 245, 150);\n    shininess(80);\n    dibujarDiamante(17);\n    pop();\n  }\n  pop();\n}\n\nfunction dibujarDiamante(s) {\n  noStroke();\n  beginShape(TRIANGLES);\n  vertex(0, -s, 0); vertex(s, 0, 0);  vertex(0, 0, s);\n  vertex(0, -s, 0); vertex(0, 0, s);  vertex(-s, 0, 0);\n  vertex(0, -s, 0); vertex(-s, 0, 0); vertex(0, 0, -s);\n  vertex(0, -s, 0); vertex(0, 0, -s); vertex(s, 0, 0);\n  vertex(0, s, 0);  vertex(0, 0, s);  vertex(s, 0, 0);\n  vertex(0, s, 0);  vertex(-s, 0, 0); vertex(0, 0, s);\n  vertex(0, s, 0);  vertex(0, 0, -s); vertex(-s, 0, 0);\n  vertex(0, s, 0);  vertex(s, 0, 0);  vertex(0, 0, -s);\n  endShape();\n}\n\nfunction dibujarBola() {\n  push();\n  translate(JUGADOR_X, JUGADOR_Y, Z_JUGADOR);\n  rotateX(moverTunel * 0.025);\n  rotateZ(-anguloMundo * 1.6);\n  ambientMaterial(65, 145, 255);\n  specularMaterial(170, 225, 255);\n  shininess(65);\n  noStroke();\n  sphere(20, 24, 16);\n  push();\n  translate(-7, -8, 14);\n  emissiveMaterial(190, 236, 255);\n  sphere(5, 10, 8);\n  pop();\n  pop();\n}\n\nfunction dibujarDisparo() {\n  if (flashDisparo <= 0.5) return;\n  push();\n  stroke(105, 205, 255, 80 * flashDisparo);\n  strokeWeight(3);\n  line(JUGADOR_X, JUGADOR_Y, Z_JUGADOR - 15, JUGADOR_X, JUGADOR_Y, -980);\n  noStroke();\n  translate(JUGADOR_X, JUGADOR_Y, Z_JUGADOR - 38);\n  emissiveMaterial(95, 205, 255);\n  sphere(6, 12, 8);\n  pop();\n}\n\n// ─── Entradas ─────────────────────────────────────────────────────────────────\nfunction mousePressed() { disparar(); }\nfunction keyPressed() {\n  if (key === \"r\" || key === \"R\") reiniciarJuego();\n  if (key === \" \") { disparar(); return false; }\n}\n\n// ─── Utilidades ───────────────────────────────────────────────────────────────\nfunction difAngulo(a, b) {\n  var d = abs(normalizarAngulo(a) - normalizarAngulo(b));\n  return min(d, TWO_PI - d);\n}\nfunction normalizarAngulo(a) { return (a % TWO_PI + TWO_PI) % TWO_PI; }"
        },
        "Asteroid.obj": {
          "k": 1,
          "c": "data:application/octet-stream;base64,"
        }
      }
    }
  }
}